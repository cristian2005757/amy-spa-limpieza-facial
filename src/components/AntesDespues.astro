---
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<section
  id="antes-despues"
  class="bg-[#F8F9FA] px-5 py-12 md:px-8 md:py-20"
  aria-label="Antes y después"
>
  <div class="mx-auto max-w-4xl px-4">
    <div class="text-center">
      <p class="section-label scroll-reveal">Resultados</p>
      <h2
        class="gsap-split-title font-display mt-2 text-3xl font-light text-[#0A0A0A] md:text-5xl"
      >
        El antes y el después real
      </h2>
      <p
        class="scroll-reveal mt-4 text-sm font-light text-[#1A1A1A]/60 md:text-base"
      >
        Resultados visibles desde la primera sesión. Sin filtros, sin edición.
      </p>
    </div>

    <div
      class="scroll-reveal mt-10 grid grid-cols-1 gap-6 md:mt-14 md:grid-cols-2 md:gap-8"
    >
      <article class="ad-card">
        <div class="ad-image-wrap">
          <span class="ad-badge ad-badge-antes">Antes</span>
          <img
            src={`${base}imagenes/antes.jpeg`}
            alt="Piel antes del tratamiento de limpieza facial"
            loading="lazy"
            width="800"
            height="900"
          />
        </div>
        <p class="ad-caption">
          Poros tapados · Piel opaca · Sin luminosidad
        </p>
      </article>

      <article class="ad-card">
        <div class="ad-image-wrap">
          <span class="ad-badge ad-badge-despues">Después</span>
          <img
            src={`${base}imagenes/despues.jpeg`}
            alt="Piel después del tratamiento de limpieza facial"
            loading="lazy"
            width="800"
            height="900"
          />
        </div>
        <p class="ad-caption">
          Poros limpios · Piel luminosa · Hidratada
        </p>
      </article>
    </div>

    <div class="scroll-reveal mt-10 flex justify-center md:mt-12">
      <span class="ad-trust">
        <span class="ad-trust-icon" aria-hidden="true">✓</span>
        Resultado real de clienta Amy Spa · Sin filtros
      </span>
    </div>
  </div>
</section>

<style>
  .ad-card {
    width: 100%;
  }

  .ad-image-wrap {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(10, 10, 10, 0.04);
  }

  .ad-placeholder {
    height: 420px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 16px;
    font-family: "Poppins", system-ui, sans-serif;
    font-size: 14px;
    letter-spacing: 0.22em;
    font-weight: 500;
  }

  .ad-placeholder-antes {
    background-color: #e5e7eb;
    color: #9ca3af;
  }

  .ad-placeholder-despues {
    background-color: #d1fae5;
    color: #065f46;
  }

  .ad-image-wrap img {
    width: 100%;
    height: 420px;
    object-fit: cover;
    display: block;
    border-radius: 16px;
  }

  .ad-badge {
    position: absolute;
    top: 14px;
    left: 14px;
    z-index: 2;
    border-radius: 8px;
    padding: 4px 12px;
    font-family: "Poppins", system-ui, sans-serif;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.04em;
    line-height: 1.4;
  }

  .ad-badge-antes {
    background-color: #ffffff;
    color: #0a0a0a;
    border: 1px solid #e5e7eb;
  }

  .ad-badge-despues {
    background-color: #0a0a0a;
    color: #ffffff;
  }

  .ad-caption {
    margin-top: 14px;
    text-align: center;
    font-family: "Poppins", system-ui, sans-serif;
    font-size: 13px;
    color: #6b7280;
    font-weight: 300;
    letter-spacing: 0.02em;
  }

  .ad-trust {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background-color: #ffffff;
    border: 1px solid #e5e7eb;
    border-radius: 999px;
    padding: 8px 20px;
    font-family: "Poppins", system-ui, sans-serif;
    font-size: 13px;
    color: #6b7280;
    font-weight: 400;
  }

  .ad-trust-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    border-radius: 999px;
    background-color: #d1fae5;
    color: #065f46;
    font-size: 11px;
    font-weight: 700;
  }

  @media (max-width: 767px) {
    .ad-placeholder,
    .ad-image-wrap img {
      height: 320px;
    }
  }
</style>
