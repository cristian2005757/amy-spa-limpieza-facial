---
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const slides = [
  {
    type: "video",
    src: `${base}videos/tratamiento-facial.mp4`,
    alt: "Tratamiento facial en cabina Amy",
  },
  {
    type: "image",
    src: `${base}imagenes/tratamiento.png`,
    alt: "Tratamiento facial profesional en Amy",
  },
  {
    type: "image",
    src: `${base}imagenes/recepcion.jpeg`,
    alt: "Recepción y espacio Amy",
  },
];

const imageDurationMs = 5000;
---

<section
  id="experiencia"
  class="bg-white px-5 py-12 md:px-8 md:py-20"
  aria-label="Vive la experiencia Amy"
>
  <div class="mx-auto max-w-6xl px-4">
    <div
      class="grid grid-cols-1 items-center gap-10 md:grid-cols-2 md:gap-14"
    >
      <div class="exp-carousel scroll-reveal" data-image-duration={imageDurationMs}>
        <div class="exp-track" role="region" aria-label="Galería Amy Spa">
          {
            slides.map((slide, i) => (
              <div
                class={`exp-slide${i === 0 ? " is-active" : ""}`}
                data-index={i}
                data-type={slide.type}
              >
                {slide.type === "video" ? (
                  <video
                    class="exp-media exp-video"
                    muted
                    playsinline
                    preload="metadata"
                    data-exp-video
                    aria-label={slide.alt}
                  >
                    <source src={slide.src} type="video/mp4" />
                  </video>
                ) : (
                  <img
                    class="exp-media exp-image"
                    src={slide.src}
                    alt={slide.alt}
                    loading="lazy"
                  />
                )}
              </div>
            ))
          }
        </div>

        <div class="exp-dots" role="tablist" aria-label="Cambiar de slide">
          {
            slides.map((_, i) => (
              <button
                type="button"
                class={`exp-dot${i === 0 ? " is-active" : ""}`}
                data-go-to={i}
                aria-label={`Ir al slide ${i + 1}`}
              />
            ))
          }
        </div>
      </div>

      <div class="exp-content">
        <p class="section-label scroll-reveal">Experiencia</p>
        <h2
          class="gsap-split-title font-display mt-3 text-3xl leading-tight font-light text-[#0A0A0A] md:text-4xl"
        >
          Vive la experiencia Amy
        </h2>
        <p class="exp-paragraph scroll-reveal mt-5">
          En Amy buscamos que te sientas cómoda, relajada y bien atendida
          desde que llegas.
        </p>

        <ul class="exp-checks scroll-reveal mt-6">
          <li class="exp-check">Atención personalizada</li>
          <li class="exp-check">Ambiente relajante</li>
          <li class="exp-check">Cabinas premium</li>
          <li class="exp-check">Cuidado profesional de la piel</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .exp-carousel {
    position: relative;
    width: 100%;
    border-radius: 20px;
    overflow: hidden;
    background-color: #f3f4f6;
    box-shadow: 0 10px 32px rgba(10, 10, 10, 0.08);
  }

  .exp-track {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 5;
    background-color: #0a0a0a;
  }

  .exp-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.6s ease;
    pointer-events: none;
  }

  .exp-slide.is-active {
    opacity: 1;
    pointer-events: auto;
  }

  .exp-media {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .exp-video {
    background-color: #0a0a0a;
  }

  .exp-dots {
    position: absolute;
    bottom: 14px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
    padding: 6px 12px;
    background-color: rgba(10, 10, 10, 0.35);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border-radius: 999px;
    z-index: 3;
  }

  .exp-dot {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    border: 0;
    background-color: rgba(255, 255, 255, 0.45);
    padding: 0;
    cursor: pointer;
    transition:
      width 0.25s ease,
      background-color 0.25s ease;
  }

  .exp-dot.is-active {
    width: 22px;
    background-color: #ffffff;
  }

  .exp-dot:hover:not(.is-active) {
    background-color: rgba(255, 255, 255, 0.75);
  }

  .exp-dot:focus-visible {
    outline: 2px solid #ffffff;
    outline-offset: 2px;
  }

  .exp-paragraph {
    font-family: "Poppins", system-ui, sans-serif;
    font-size: 17px;
    color: #6b7280;
    line-height: 1.7;
    font-weight: 300;
  }

  .exp-checks {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .exp-check {
    font-family: "Poppins", system-ui, sans-serif;
    font-size: 16px;
    color: #0a0a0a;
    font-weight: 400;
    line-height: 1.5;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .exp-check::before {
    content: "✔";
    color: var(--green-deep, #7ebc83);
    font-weight: 700;
    font-size: 14px;
    flex-shrink: 0;
  }

  @media (max-width: 767px) {
    .exp-track {
      aspect-ratio: 4 / 5;
    }

    .exp-paragraph {
      font-size: 15px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .exp-slide {
      transition: none;
    }
  }
</style>

<script>
  (function () {
    const carousels = document.querySelectorAll(".exp-carousel");
    if (!carousels.length) return;

    carousels.forEach((carousel) => {
      const slides = carousel.querySelectorAll(".exp-slide");
      const dots = carousel.querySelectorAll(".exp-dot");
      const video = carousel.querySelector("[data-exp-video]");
      const imageDuration =
        parseInt(carousel.getAttribute("data-image-duration") || "5000", 10) ||
        5000;

      if (!slides.length) return;

      let currentIndex = 0;
      let imageTimer = null;

      function clearImageTimer() {
        if (imageTimer) {
          clearTimeout(imageTimer);
          imageTimer = null;
        }
      }

      function setActive(index) {
        clearImageTimer();
        currentIndex = (index + slides.length) % slides.length;

        slides.forEach((slide, i) => {
          if (i === currentIndex) slide.classList.add("is-active");
          else slide.classList.remove("is-active");
        });

        dots.forEach((dot, i) => {
          if (i === currentIndex) dot.classList.add("is-active");
          else dot.classList.remove("is-active");
        });

        const activeSlide = slides[currentIndex];
        const type = activeSlide.getAttribute("data-type");

        if (type === "video" && video) {
          try {
            video.currentTime = 0;
          } catch (_) {}
          const playPromise = video.play();
          if (playPromise && typeof playPromise.catch === "function") {
            playPromise.catch(() => {
              imageTimer = setTimeout(next, imageDuration);
            });
          }
        } else {
          if (video && !video.paused) {
            try {
              video.pause();
            } catch (_) {}
          }
          imageTimer = setTimeout(next, imageDuration);
        }
      }

      function next() {
        setActive(currentIndex + 1);
      }

      dots.forEach((dot) => {
        dot.addEventListener("click", () => {
          const target = parseInt(dot.getAttribute("data-go-to") || "0", 10);
          setActive(target);
        });
      });

      if (video) {
        video.addEventListener("ended", () => {
          if (currentIndex === 0) next();
        });
        video.addEventListener("error", () => {
          if (currentIndex === 0) {
            imageTimer = setTimeout(next, imageDuration);
          }
        });
      }

      setActive(0);
    });
  })();
</script>
