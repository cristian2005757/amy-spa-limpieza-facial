    <script>
      /* ——— Navbar ——— */
      const toggle = document.getElementById("menu-toggle");
      const menu = document.getElementById("mobile-menu");
      const navbar = document.getElementById("navbar");
      const navLinks = document.querySelectorAll(".mobile-nav-link");

      toggle?.addEventListener("click", () => {
        const isOpen = menu?.classList.toggle("hidden") === false;
        navbar?.classList.toggle("nav-open", isOpen);
        toggle.setAttribute("aria-expanded", String(isOpen));
        toggle.setAttribute("aria-label", isOpen ? "Cerrar menú" : "Abrir menú");
      });

      navLinks.forEach((link) => {
        link.addEventListener("click", () => {
          menu?.classList.add("hidden");
          navbar?.classList.remove("nav-open");
          toggle?.setAttribute("aria-expanded", "false");
          toggle?.setAttribute("aria-label", "Abrir menú");
        });
      });

      const updateNavbar = () => {
        navbar?.classList.toggle("navbar-scrolled", window.scrollY > 50);
      };

      updateNavbar();
      window.addEventListener("scroll", updateNavbar, { passive: true });

      /* ——— Carrusel reutilizable ——— */
      function initCarousel({
        trackId,
        prevId,
        nextId,
        dotsId,
        cardSelector,
        autoplay,
        alignCenter,
      }) {
        const track = document.getElementById(trackId);
        if (!track) return;
        const prev = prevId ? document.getElementById(prevId) : null;
        const next = nextId ? document.getElementById(nextId) : null;
        const dotsWrap = dotsId ? document.getElementById(dotsId) : null;
        const cards = Array.from(track.querySelectorAll(cardSelector));
        const dots = dotsWrap
          ? Array.from(dotsWrap.querySelectorAll(".reels-dot"))
          : [];

        if (!cards.length) return;

        const getStep = () => {
          const card = cards[0];
          const styles = getComputedStyle(track);
          const gap = parseFloat(styles.columnGap || styles.gap || "0") || 0;
          return card.getBoundingClientRect().width + gap;
        };

        const getActiveIndex = () => {
          const trackRect = track.getBoundingClientRect();
          const anchor = alignCenter
            ? trackRect.left + trackRect.width / 2
            : trackRect.left + 24;
          let bestIdx = 0;
          let bestDist = Infinity;
          cards.forEach((card, i) => {
            const r = card.getBoundingClientRect();
            const cardAnchor = alignCenter ? r.left + r.width / 2 : r.left;
            const dist = Math.abs(cardAnchor - anchor);
            if (dist < bestDist) {
              bestDist = dist;
              bestIdx = i;
            }
          });
          return bestIdx;
        };

        const update = () => {
          const idx = getActiveIndex();
          dots.forEach((d, i) => d.classList.toggle("is-active", i === idx));
          if (prev) {
            const atStart = track.scrollLeft <= 2;
            prev.setAttribute("aria-disabled", String(atStart));
            prev.disabled = atStart;
          }
          if (next) {
            const atEnd =
              track.scrollLeft + track.clientWidth >= track.scrollWidth - 2;
            next.setAttribute("aria-disabled", String(atEnd));
            next.disabled = atEnd;
          }
        };

        const scrollToCard = (i) => {
          const target = cards[i];
          if (!target) return;
          const offset = alignCenter
            ? target.offsetLeft -
              (track.clientWidth - target.clientWidth) / 2
            : target.offsetLeft;
          track.scrollTo({ left: offset, behavior: "smooth" });
        };

        prev?.addEventListener("click", () => {
          track.scrollBy({ left: -getStep(), behavior: "smooth" });
        });

        next?.addEventListener("click", () => {
          track.scrollBy({ left: getStep(), behavior: "smooth" });
        });

        dots.forEach((dot, i) => {
          dot.addEventListener("click", () => scrollToCard(i));
        });

        let raf = 0;
        track.addEventListener(
          "scroll",
          () => {
            cancelAnimationFrame(raf);
            raf = requestAnimationFrame(update);
          },
          { passive: true }
        );

        window.addEventListener("resize", update, { passive: true });
        update();

        if (autoplay) {
          let timer = 0;
          let paused = false;

          const tick = () => {
            if (paused) return;
            const atEnd =
              track.scrollLeft + track.clientWidth >= track.scrollWidth - 2;
            if (atEnd) {
              track.scrollTo({ left: 0, behavior: "smooth" });
            } else {
              track.scrollBy({ left: getStep(), behavior: "smooth" });
            }
          };

          const start = () => {
            stop();
            timer = window.setInterval(tick, autoplay);
          };
          const stop = () => {
            if (timer) {
              window.clearInterval(timer);
              timer = 0;
            }
          };

          track.addEventListener("mouseenter", () => {
            paused = true;
          });
          track.addEventListener("mouseleave", () => {
            paused = false;
          });
          track.addEventListener("focusin", () => {
            paused = true;
          });
          track.addEventListener("focusout", () => {
            paused = false;
          });
          document.addEventListener("visibilitychange", () => {
            if (document.hidden) stop();
            else start();
          });

          if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
            return;
          }
          start();
        }
      }

      initCarousel({
        trackId: "google-track",
        prevId: "google-prev",
        nextId: "google-next",
        dotsId: "google-dots",
        cardSelector: ".google-card",
        autoplay: 4000,
        alignCenter: false,
      });
    </script>

    <script>
      import { gsap } from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";
      import { SplitText } from "gsap/SplitText";

      document.addEventListener("DOMContentLoaded", () => {
        gsap.registerPlugin(ScrollTrigger, SplitText);

        const prefersReducedMotion = window.matchMedia(
          "(prefers-reduced-motion: reduce)"
        ).matches;

        const easeLuxury = "power2.out";
        const easeHero = "power3.out";

        /** Fallback: restaura visibilidad si GSAP o ScrollTrigger fallan */
        function revealFallback() {
          gsap.set(
            [
              ".scroll-reveal",
              ".gsap-split-title",
              ".service-price-card",
              "#cta-content",
              "#cta-btn",
              "#footer",
              "#hero-title",
              "#hero-subtitle",
              "#hero-cta",
              "#hero-badge",
              "#hero-urgency",
              ".hero-scroll-indicator",
              ".benefit-card",
              ".emotional-banner",
              ".uso-pill",
              ".compare-table",
              ".tech-badge",
              ".reel-card",
              ".google-card",
              ".google-summary",
            ],
            { opacity: 1, y: 0, x: 0, scale: 1, autoAlpha: 1, clearProps: "transform" }
          );
        }

        function safeSplitText(element, config) {
          if (!element) return null;
          try {
            return SplitText.create(element, config);
          } catch (err) {
            console.warn("[GSAP] SplitText omitido:", element, err);
            return null;
          }
        }

        function scrollReveal(targets, trigger, options = {}) {
          const els = gsap.utils.toArray(targets);
          if (!els.length || !trigger) return;

          gsap.fromTo(
            els,
            { opacity: 0, y: 30 },
            {
              opacity: 1,
              y: 0,
              duration: 0.7,
              ease: easeLuxury,
              stagger: 0.1,
              immediateRender: false,
              ...options,
              scrollTrigger: {
                trigger,
                start: "top 85%",
                toggleActions: "play none none none",
                once: true,
                ...options.scrollTrigger,
              },
            }
          );
        }

        function initHero() {
          const hero = document.querySelector("#hero");
          const video = document.querySelector("#hero-video");
          const overlay = document.querySelector("#hero-overlay");
          const title = document.querySelector("#hero-title");
          const subtitle = document.querySelector("#hero-subtitle");
          const cta = document.querySelector("#hero-cta");
          const badge = document.querySelector("#hero-badge");
          const urgency = document.querySelector("#hero-urgency");
          const scrollIndicator = document.querySelector(".hero-scroll-indicator");

          if (!hero) return;

          const tl = gsap.timeline({ defaults: { ease: easeHero } });

          if (overlay) {
            tl.fromTo(overlay, { opacity: 0 }, { opacity: 1, duration: 1.2 }, 0);
          }

          if (video) {
            tl.fromTo(
              video,
              { scale: 1.08 },
              { scale: 1, duration: 2.2, ease: "power2.out" },
              0
            );
          }

          if (urgency) {
            tl.fromTo(
              urgency,
              { y: 14, opacity: 0 },
              { y: 0, opacity: 1, duration: 0.65 },
              0.25
            );
          }

          if (badge) {
            tl.fromTo(
              badge,
              { y: 12, opacity: 0 },
              { y: 0, opacity: 1, duration: 0.7 },
              0.4
            );
          }

          if (title) {
            const split = safeSplitText(title, {
              type: "words",
              wordsClass: "hero-word",
            });

            if (split?.words?.length) {
              tl.fromTo(
                split.words,
                { yPercent: 110, opacity: 0 },
                {
                  yPercent: 0,
                  opacity: 1,
                  duration: 0.95,
                  stagger: 0.07,
                  ease: easeHero,
                },
                0.55
              );
            } else {
              tl.fromTo(
                title,
                { y: 24, opacity: 0 },
                { y: 0, opacity: 1, duration: 0.9 },
                0.55
              );
            }
          }

          if (subtitle) {
            tl.fromTo(
              subtitle,
              { y: 28, opacity: 0 },
              { y: 0, opacity: 1, duration: 0.85 },
              0.9
            );
          }

          if (cta) {
            tl.fromTo(
              cta,
              { y: 20, opacity: 0, scale: 0.96 },
              { y: 0, opacity: 1, scale: 1, duration: 0.75 },
              1.1
            );
          }

          if (scrollIndicator) {
            tl.fromTo(
              scrollIndicator,
              { opacity: 0 },
              { opacity: 1, duration: 0.6 },
              1.45
            );
          }

          if (video) {
            gsap.fromTo(
              video,
              { yPercent: 0 },
              {
                yPercent: 12,
                ease: "none",
                scrollTrigger: {
                  trigger: hero,
                  start: "top top",
                  end: "bottom top",
                  scrub: 1.2,
                },
              }
            );
          }
        }

        function initNavbarEntrance() {
          const navbar = document.querySelector("#navbar");
          if (!navbar) return;

          gsap.fromTo(
            navbar,
            { y: -24, opacity: 0 },
            { y: 0, opacity: 1, duration: 0.9, ease: easeHero, delay: 0.15 }
          );
        }

        function initSectionReveals() {
          document
            .querySelectorAll(
              "#beneficios, #testimonios, #comparativa, #google, #servicios, #faq, #contacto"
            )
            .forEach((section) => {
              const reveals = section.querySelectorAll(
                ".scroll-reveal:not(.service-price-card)"
              );
              scrollReveal(reveals, section);
            });
        }

        function initSplitTitles() {
          document.querySelectorAll(".gsap-split-title").forEach((title) => {
            const section = title.closest("section");
            if (!section) return;

            const split = safeSplitText(title, {
              type: "words",
              wordsClass: "split-word",
            });

            if (!split?.words?.length) return;

            gsap.fromTo(
              split.words,
              { opacity: 0, y: 18 },
              {
                opacity: 1,
                y: 0,
                duration: 0.65,
                stagger: 0.04,
                ease: easeLuxury,
                immediateRender: false,
                scrollTrigger: {
                  trigger: section,
                  start: "top 85%",
                  toggleActions: "play none none none",
                  once: true,
                },
              }
            );
          });
        }

        function initServiceCards() {
          const cards = document.querySelectorAll(".service-price-card");
          const section = document.querySelector("#servicios");
          if (!cards.length || !section) return;

          gsap.fromTo(
            cards,
            { opacity: 0, y: 36, scale: 0.97 },
            {
              opacity: 1,
              y: 0,
              scale: 1,
              duration: 0.75,
              ease: easeLuxury,
              stagger: 0.12,
              immediateRender: false,
              scrollTrigger: {
                trigger: section,
                start: "top 80%",
                toggleActions: "play none none none",
                once: true,
              },
            }
          );
        }

        function initCta() {
          const section = document.querySelector("#contacto");
          const block = document.querySelector("#cta-content");
          const btn = document.querySelector("#cta-btn");
          if (!section || !block) return;

          const tl = gsap.timeline({
            scrollTrigger: {
              trigger: section,
              start: "top 82%",
              toggleActions: "play none none none",
              once: true,
            },
          });

          tl.fromTo(
            block,
            { opacity: 0, y: 32 },
            { opacity: 1, y: 0, duration: 0.75, ease: easeLuxury }
          );

          if (btn) {
            tl.fromTo(
              btn,
              { scale: 0.9, opacity: 0 },
              { scale: 1, opacity: 1, duration: 0.55, ease: "back.out(1.4)" },
              "-=0.35"
            );
          }
        }

        function initFooter() {
          const footer = document.querySelector("#footer");
          if (!footer) return;

          gsap.fromTo(
            footer,
            { opacity: 0, y: 24 },
            {
              opacity: 1,
              y: 0,
              duration: 0.7,
              ease: easeLuxury,
              immediateRender: false,
              scrollTrigger: {
                trigger: footer,
                start: "top 95%",
                toggleActions: "play none none none",
                once: true,
              },
            }
          );
        }

        function initAnimations() {
          gsap.set("#hero-subtitle, #hero-cta, #hero-badge, #hero-urgency, .hero-scroll-indicator", {
            autoAlpha: 0,
          });
          gsap.set(".scroll-reveal", { opacity: 0, y: 30 });

          if (prefersReducedMotion) {
            revealFallback();
            return;
          }

          try {
            initHero();
            initNavbarEntrance();
            initSectionReveals();
            initSplitTitles();
            initServiceCards();
            initCta();
            initFooter();

            ScrollTrigger.refresh();

            window.addEventListener("load", () => {
              ScrollTrigger.refresh();
            });
          } catch (err) {
            console.error("[GSAP] Error al inicializar animaciones:", err);
            revealFallback();
          }
        }

        initAnimations();

        /* Si tras 2.5s algo sigue invisible, forzar fallback */
        setTimeout(() => {
          const selectors =
            ".scroll-reveal, .service-price-card, #cta-content, .gsap-split-title";
          const stuck = [...document.querySelectorAll(selectors)].some(
            (el) => parseFloat(getComputedStyle(el).opacity) < 0.05
          );
          if (stuck) {
            console.warn("[GSAP] Fallback de visibilidad activado");
            revealFallback();
            ScrollTrigger.refresh();
          }
        }, 2500);
      });
    </script>
