---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href={`${base}imagenes/logo.png`} />
    <link rel="apple-touch-icon" href={`${base}imagenes/logo.png`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0A0A0A" />
    <meta
      name="description"
      content="Amy Spa — Limpieza facial profesional con resultados visibles desde la primera sesión. Reserva tu cita en Bogotá."
    />
    <meta name="generator" content={Astro.generator} />
    <title>Amy Spa | Limpieza Facial Profesional en Bogotá</title>

    <meta property="og:type" content="website" />
    <meta property="og:title" content="Amy Spa | Limpieza Facial Profesional en Bogotá" />
    <meta
      property="og:description"
      content="Limpieza facial profesional con resultados visibles desde la primera sesión. Reserva tu cita hoy."
    />
    <meta property="og:image" content={`${base}imagenes/logo.png`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Amy Spa | Limpieza Facial Profesional" />
    <meta
      name="twitter:description"
      content="Limpieza facial profesional con resultados visibles desde la primera sesión."
    />
    <meta name="twitter:image" content={`${base}imagenes/logo.png`} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500&display=swap"
      rel="stylesheet"
    />

    <style is:global>
      @import "tailwindcss";

      :root {
        --white: #ffffff;

        --gray-50: #fafafa;
        --gray-100: #f5f5f5;
        --gray-200: #e8e8e8;
        --gray-300: #d4d4d4;
        --gray-400: #a3a3a3;
        --gray-500: #737373;
        --gray-600: #525252;
        --gray-700: #404040;
        --gray-800: #262626;
        --gray-900: #0a0a0a;

        --green-soft: #e8f3e5;
        --green-light: #c8e5c2;
        --green: #a8d5a2;
        --green-deep: #7ebc83;
        --green-darker: #5fa665;

        --cream: var(--gray-100);
        --pale-pink: var(--green);
        --soft-black: var(--gray-800);
        --deep-black: var(--gray-900);
        --whatsapp: var(--green-deep);
        --whatsapp-dark: var(--green-darker);
        --price-red: var(--gray-700);
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: "Poppins", system-ui, sans-serif;
        font-weight: 300;
        color: var(--soft-black);
        background-color: #ffffff;
      }

      h1,
      h2 {
        font-family: "Poppins", system-ui, sans-serif;
        font-weight: 500;
        letter-spacing: -0.02em;
      }

      .font-display {
        font-family: "Poppins", system-ui, sans-serif;
        font-weight: 500;
        letter-spacing: -0.02em;
      }

      .nav-logo {
        font-family: "Poppins", system-ui, sans-serif;
        font-style: italic;
        font-weight: 400;
        letter-spacing: 0;
      }

      .nav-logo-img {
        display: block;
        object-fit: contain;
        border-radius: 10px;
        filter: drop-shadow(0 6px 18px rgba(0, 0, 0, 0.35));
        margin-top: -12px;
        margin-bottom: -12px;
      }

      @media (min-width: 768px) {
        .nav-logo-img {
          margin-top: -16px;
          margin-bottom: -16px;
        }
      }

      #navbar.navbar-scrolled .nav-logo-img {
        filter: drop-shadow(0 2px 8px rgba(0, 0, 0, 0.12));
      }

      p,
      li,
      blockquote,
      .faq-answer p,
      .testimonial-card-slide .quote-text {
        font-family: "Poppins", system-ui, sans-serif;
        font-weight: 300;
      }

      .nav-cta,
      .nav-link,
      .mobile-nav-link,
      #mobile-menu a.rounded-full,
      .section-label {
        font-family: "Poppins", system-ui, sans-serif;
        font-weight: 500;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .section-label {
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 0.2em;
        color: var(--green-deep);
      }

      .section-label-dark {
        color: rgba(255, 255, 255, 0.55);
      }

      /* ===== HERO ===== */
      .hero-gradient {
        background:
          radial-gradient(
            ellipse at center,
            rgba(0, 0, 0, 0.28) 0%,
            rgba(0, 0, 0, 0.12) 45%,
            rgba(0, 0, 0, 0) 75%
          ),
          linear-gradient(
            to bottom,
            rgba(0, 0, 0, 0) 0%,
            rgba(0, 0, 0, 0.05) 60%,
            rgba(0, 0, 0, 0.22) 100%
          );
      }

      #hero-title {
        text-shadow:
          0 2px 18px rgba(0, 0, 0, 0.32),
          0 1px 3px rgba(0, 0, 0, 0.22);
      }

      #hero-subtitle {
        text-shadow: 0 1px 10px rgba(0, 0, 0, 0.32);
      }

      .hero-price .price-new {
        text-shadow: 0 2px 14px rgba(0, 0, 0, 0.3);
      }

      .hero-glass-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border-radius: 9999px;
        border: 1px solid rgba(255, 255, 255, 0.35);
        background: rgba(255, 255, 255, 0.12);
        padding: 10px 20px;
        font-size: 13px;
        color: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
      }

      .urgency-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border-radius: 9999px;
        background: linear-gradient(
          135deg,
          var(--green) 0%,
          var(--green-deep) 100%
        );
        padding: 10px 20px;
        font-size: 13px;
        font-weight: 600;
        color: var(--gray-900);
        box-shadow: 0 8px 24px rgba(126, 188, 131, 0.35);
      }

      .hero-price {
        display: inline-flex;
        flex-wrap: wrap;
        align-items: baseline;
        justify-content: center;
        gap: 14px;
        margin-top: 24px;
      }

      .hero-price .price-old {
        font-family: "Poppins", system-ui, sans-serif;
        font-size: 18px;
        font-weight: 400;
        color: rgba(255, 255, 255, 0.6);
        text-decoration: line-through;
      }

      .hero-price .price-new {
        font-family: "Poppins", system-ui, sans-serif;
        font-size: 36px;
        font-weight: 600;
        color: #ffffff;
        letter-spacing: -0.02em;
      }

      .hero-price .price-currency {
        font-family: "Poppins", system-ui, sans-serif;
        font-size: 14px;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.85);
        letter-spacing: 0.1em;
      }

      .btn-cta-primary {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        border-radius: 9999px;
        background-color: var(--deep-black);
        color: #ffffff;
        padding: 18px 36px;
        font-family: "Poppins", system-ui, sans-serif;
        font-size: 14px;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        box-shadow: 0 12px 32px rgba(10, 10, 10, 0.25);
        transition:
          transform 0.3s ease,
          background-color 0.3s ease,
          box-shadow 0.3s ease;
      }

      .btn-cta-primary:hover {
        transform: translateY(-2px) scale(1.02);
        background-color: var(--whatsapp);
        box-shadow: 0 16px 40px rgba(37, 211, 102, 0.4);
      }

      .btn-cta-primary.btn-cta-xl {
        padding: 22px 44px;
        font-size: 15px;
      }

      .btn-cta-white {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        border-radius: 9999px;
        background-color: #ffffff;
        color: var(--deep-black);
        padding: 18px 36px;
        font-family: "Poppins", system-ui, sans-serif;
        font-size: 14px;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        box-shadow: 0 12px 32px rgba(0, 0, 0, 0.25);
        transition:
          transform 0.3s ease,
          background-color 0.3s ease,
          color 0.3s ease;
      }

      .btn-cta-white:hover {
        transform: translateY(-2px) scale(1.02);
        background-color: var(--whatsapp);
        color: #ffffff;
      }

      .hero-scroll-indicator {
        position: absolute;
        bottom: 2rem;
        left: 50%;
        z-index: 10;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        transform: translateX(-50%);
        color: rgba(255, 255, 255, 0.7);
        font-size: 11px;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        transition: color 0.3s ease;
      }

      .hero-scroll-indicator:hover {
        color: #ffffff;
      }

      .hero-scroll-line {
        display: block;
        width: 1px;
        height: 40px;
        background: linear-gradient(
          to bottom,
          rgba(255, 255, 255, 0.8),
          transparent
        );
        animation: scroll-pulse 2s ease-in-out infinite;
      }

      @keyframes scroll-pulse {
        0%,
        100% {
          transform: scaleY(1);
          opacity: 0.6;
        }
        50% {
          transform: scaleY(0.6);
          opacity: 1;
        }
      }

      /* ===== BENEFICIOS ===== */
      .benefit-card {
        position: relative;
        background-color: #ffffff;
        border: 1px solid var(--gray-200);
        border-radius: 22px;
        padding: 2.5rem 1.75rem 2rem;
        text-align: center;
        overflow: hidden;
        transition:
          transform 0.35s ease,
          box-shadow 0.35s ease,
          border-color 0.35s ease;
      }

      .benefit-card:hover {
        transform: translateY(-6px);
        border-color: var(--green);
        box-shadow: 0 24px 50px rgba(26, 26, 26, 0.08);
      }

      .benefit-num {
        position: absolute;
        top: 1rem;
        right: 1.5rem;
        font-family: "Poppins", system-ui, sans-serif;
        font-size: 4rem;
        font-weight: 700;
        line-height: 1;
        color: var(--gray-100);
        letter-spacing: -0.04em;
        pointer-events: none;
        z-index: 0;
      }

      .benefit-card > *:not(.benefit-num) {
        position: relative;
        z-index: 1;
      }

      .benefit-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 4.25rem;
        height: 4.25rem;
        border-radius: 9999px;
        background-color: var(--green-soft);
        color: var(--green-deep);
      }

      .benefit-stat {
        display: inline-block;
        margin-top: 0.5rem;
        padding: 4px 12px;
        border-radius: 9999px;
        background-color: var(--gray-100);
        font-family: "Poppins", system-ui, sans-serif;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        color: var(--gray-700);
      }

      .emotional-banner {
        position: relative;
        background: linear-gradient(
          135deg,
          var(--green-soft) 0%,
          #ffffff 50%,
          var(--green-soft) 100%
        );
        padding: 1.75rem;
        border-radius: 28px;
        border: 1px solid rgba(168, 213, 162, 0.4);
        overflow: hidden;
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.75rem;
        align-items: center;
      }

      @media (min-width: 768px) {
        .emotional-banner {
          grid-template-columns: minmax(220px, 280px) 1fr;
          padding: 2rem 2.5rem;
          gap: 2.5rem;
        }
      }

      @media (min-width: 1024px) {
        .emotional-banner {
          grid-template-columns: minmax(260px, 320px) 1fr;
          padding: 2.5rem 3rem;
          gap: 3rem;
        }
      }

      .emotional-video-wrap {
        position: relative;
        width: 100%;
        max-width: 320px;
        margin: 0 auto;
        aspect-ratio: 9 / 16;
        border-radius: 22px;
        overflow: hidden;
        background-color: #0a0a0a;
        box-shadow:
          0 20px 40px rgba(26, 26, 26, 0.18),
          0 0 0 1px rgba(168, 213, 162, 0.35);
      }

      .emotional-video {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }

      .emotional-content {
        position: relative;
        text-align: center;
        padding-top: 1rem;
      }

      @media (min-width: 768px) {
        .emotional-content {
          text-align: left;
          padding-top: 0;
        }
      }

      .emotional-quote {
        position: absolute;
        top: -3rem;
        left: 50%;
        transform: translateX(-50%);
        font-family: "Poppins", system-ui, sans-serif;
        font-size: 7rem;
        line-height: 1;
        color: rgba(168, 213, 162, 0.55);
        pointer-events: none;
        user-select: none;
      }

      @media (min-width: 768px) {
        .emotional-quote {
          left: -0.5rem;
          transform: none;
          top: -3.5rem;
          font-size: 8rem;
        }
      }

      .emotional-banner p {
        position: relative;
        font-family: "Poppins", system-ui, sans-serif;
        font-size: clamp(1.5rem, 4vw, 2.4rem);
        font-weight: 500;
        font-style: italic;
        line-height: 1.3;
        letter-spacing: -0.02em;
        color: var(--soft-black);
      }

      .emotional-rule {
        position: relative;
        display: block;
        width: 48px;
        height: 2px;
        margin: 1.25rem auto 0;
        background-color: var(--green-deep);
        border-radius: 2px;
      }

      @media (min-width: 768px) {
        .emotional-rule {
          margin: 1.25rem 0 0;
        }
      }

      .emotional-caption {
        font-size: 13px !important;
        font-style: normal !important;
        font-weight: 400 !important;
        letter-spacing: 0.04em !important;
        color: rgba(10, 10, 10, 0.55) !important;
        margin-top: 0.75rem;
      }

      .emotional-eyebrow {
        font-family: "Poppins", system-ui, sans-serif;
        font-size: 11px !important;
        font-weight: 500 !important;
        font-style: normal !important;
        line-height: 1.4 !important;
        letter-spacing: 0.2em !important;
        text-transform: uppercase;
        color: var(--green-deep) !important;
        margin-bottom: 0.75rem;
      }

      .solucion-checks {
        list-style: none;
        padding: 0;
        margin: 24px 0 0;
        display: inline-flex;
        flex-direction: column;
        gap: 12px;
        text-align: left;
      }

      .solucion-check {
        font-family: "Poppins", system-ui, sans-serif;
        font-size: 16px;
        font-weight: 400;
        font-style: normal;
        line-height: 1.5;
        color: #0a0a0a;
        display: flex;
        align-items: center;
        gap: 10px;
      }

      .solucion-check::before {
        content: "✔";
        color: var(--green-deep);
        font-weight: 700;
        font-size: 14px;
        flex-shrink: 0;
      }

      .solucion-cta {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        margin-top: 32px;
        padding: 14px 32px;
        background-color: #0a0a0a;
        color: #ffffff;
        border-radius: 999px;
        font-family: "Poppins", system-ui, sans-serif;
        font-size: 15px;
        font-weight: 500;
        text-decoration: none;
        letter-spacing: 0.01em;
        transition:
          background-color 0.25s ease,
          transform 0.15s ease,
          box-shadow 0.25s ease;
        box-shadow: 0 4px 12px rgba(10, 10, 10, 0.12);
      }

      .solucion-cta:hover {
        background-color: var(--green-deep);
        transform: translateY(-1px);
        box-shadow: 0 6px 18px rgba(126, 188, 131, 0.35);
      }

      .solucion-cta:focus-visible {
        outline: 2px solid var(--green-deep);
        outline-offset: 3px;
      }

      .uso-block {
        background-color: #ffffff;
        border: 1px solid var(--gray-200);
        border-radius: 20px;
        padding: 1.5rem 1.5rem 1.75rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        align-items: center;
        text-align: center;
      }

      @media (min-width: 768px) {
        .uso-block {
          flex-direction: row;
          justify-content: space-between;
          padding: 1.5rem 2rem;
          text-align: left;
        }
      }

      .uso-block-head {
        display: flex;
        flex-direction: column;
        gap: 4px;
      }

      .uso-block-eyebrow {
        font-family: "Poppins", system-ui, sans-serif;
        font-size: 10px;
        font-weight: 600;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--green-deep);
      }

      .uso-block-title {
        font-family: "Poppins", system-ui, sans-serif;
        font-size: 14px;
        font-weight: 500;
        color: var(--gray-900);
      }

      .uso-block-pills {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 10px;
      }

      .uso-pill {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 18px;
        border-radius: 9999px;
        border: 1px solid var(--green);
        background-color: var(--green-soft);
        color: var(--gray-800);
        font-size: 13px;
        font-weight: 500;
        letter-spacing: 0.02em;
        transition:
          background-color 0.25s ease,
          transform 0.25s ease,
          border-color 0.25s ease;
      }

      .uso-pill:hover {
        background-color: var(--green-light);
        border-color: var(--green-deep);
        transform: translateY(-2px);
      }

      .uso-pill-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 22px;
        height: 22px;
        border-radius: 50%;
        background-color: #ffffff;
        color: var(--green-deep);
      }

      /* ===== TESTIMONIOS ===== */
      .testimonial-slider-wrap {
        overflow: hidden;
        width: 100%;
        mask-image: linear-gradient(
          to right,
          transparent 0%,
          black 8%,
          black 92%,
          transparent 100%
        );
        -webkit-mask-image: linear-gradient(
          to right,
          transparent 0%,
          black 8%,
          black 92%,
          transparent 100%
        );
      }

      .testimonial-slider-wrap:hover .testimonial-slider-track {
        animation-play-state: paused;
      }

      .testimonial-slider-track {
        display: flex;
        width: max-content;
        gap: 24px;
        animation: testimonial-slide 36s linear infinite;
        will-change: transform;
      }

      @keyframes testimonial-slide {
        0% {
          transform: translateX(0);
        }
        100% {
          transform: translateX(calc(-380px * 6 - 24px * 6));
        }
      }

      .testimonial-card-slide {
        flex-shrink: 0;
        width: 380px;
        padding: 28px;
        background-color: #ffffff;
        border: 1px solid #e8e8e8;
        border-radius: 16px;
        box-shadow: 0 2px 20px rgba(0, 0, 0, 0.06);
      }

      .testimonial-card-slide .stars {
        font-size: 14px;
        letter-spacing: 2px;
      }

      .testimonial-card-slide .quote-text {
        margin-top: 14px;
        font-size: 16px;
        line-height: 1.6;
        font-style: italic;
        color: #0a0a0a;
      }

      .testimonial-card-slide .author-row {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-top: 22px;
      }

      .testimonial-card-slide .author {
        font-family: "Poppins", system-ui, sans-serif;
        font-size: 15px;
        font-weight: 500;
        color: #0a0a0a;
      }

      .testimonial-card-slide .author-meta {
        font-size: 12px;
        color: rgba(10, 10, 10, 0.55);
      }

      .testimonial-card-slide .treatment-tag {
        margin-top: 16px;
        display: inline-block;
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 0.05em;
        color: var(--green-deep);
        background-color: var(--green-soft);
        padding: 6px 12px;
        border-radius: 9999px;
      }

      .testimonial-avatar {
        width: 56px;
        height: 56px;
        flex-shrink: 0;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid var(--cream);
      }

      .testimonial-avatar-initial {
        display: flex;
        width: 56px;
        height: 56px;
        flex-shrink: 0;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        background-color: var(--cream);
        font-family: "Poppins", system-ui, sans-serif;
        font-size: 22px;
        font-weight: 500;
        color: var(--soft-black);
      }

      /* ===== GOOGLE REVIEWS ===== */
      .google-pill {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 18px;
        border-radius: 9999px;
        background-color: #ffffff;
        border: 1px solid #e8e8e8;
        font-size: 13px;
        color: rgba(10, 10, 10, 0.75);
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.04);
      }

      .google-pill strong {
        font-weight: 700;
        color: var(--deep-black);
      }

      .google-pill-stars {
        color: var(--green-deep);
      }

      .google-pill-sep {
        color: rgba(10, 10, 10, 0.25);
      }

      .google-summary {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
        padding: 1.75rem 1.5rem;
        background-color: #ffffff;
        border: 1px solid #ececec;
        border-radius: 20px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.04);
        max-width: 360px;
        margin-left: auto;
        margin-right: auto;
      }

      .google-summary-logo {
        display: inline-flex;
      }

      .google-summary-rating {
        font-family: "Poppins", system-ui, sans-serif;
        font-size: 44px;
        font-weight: 600;
        color: var(--deep-black);
        line-height: 1;
        letter-spacing: -0.02em;
      }

      .google-summary-stars {
        color: #FBBC04;
        font-size: 22px;
        letter-spacing: 4px;
      }

      .google-summary-text {
        font-size: 13px;
        color: rgba(10, 10, 10, 0.6);
      }

      .google-carousel-wrap {
        position: relative;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .google-track {
        display: flex;
        gap: 1.25rem;
        overflow-x: auto;
        overflow-y: hidden;
        scroll-snap-type: x mandatory;
        scroll-behavior: smooth;
        scrollbar-width: none;
        -ms-overflow-style: none;
        -webkit-overflow-scrolling: touch;
        padding: 1rem 0.25rem 1.5rem;
        flex: 1;
      }

      .google-track::-webkit-scrollbar {
        display: none;
      }

      .google-track:focus-visible {
        outline: 2px solid var(--pale-pink);
        outline-offset: 4px;
        border-radius: 12px;
      }

      .google-card {
        flex: 0 0 calc(100% - 0.5rem);
        max-width: 100%;
        scroll-snap-align: start;
        display: flex;
        flex-direction: column;
        gap: 14px;
        padding: 24px;
        background-color: #ffffff;
        border: 1px solid #ececec;
        border-radius: 18px;
        box-shadow: 0 6px 24px rgba(0, 0, 0, 0.05);
      }

      @media (min-width: 640px) {
        .google-card {
          flex: 0 0 calc(50% - 0.625rem);
        }
      }

      @media (min-width: 1024px) {
        .google-card {
          flex: 0 0 calc(33.333% - 0.834rem);
        }
      }

      .google-card-head {
        display: flex;
        align-items: flex-start;
        gap: 14px;
      }

      .google-avatar {
        flex-shrink: 0;
        width: 44px;
        height: 44px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: "Poppins", system-ui, sans-serif;
        font-weight: 600;
        font-size: 18px;
        color: #ffffff;
        overflow: hidden;
      }

      .google-avatar-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }

      .google-card-meta {
        flex: 1;
        min-width: 0;
      }

      .google-card-name {
        font-family: "Poppins", system-ui, sans-serif;
        font-weight: 600;
        font-size: 15px;
        color: var(--deep-black);
        line-height: 1.25;
      }

      .google-card-row {
        margin-top: 4px;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 6px;
      }

      .google-stars {
        color: #FBBC04;
        font-size: 14px;
        letter-spacing: 2px;
      }

      .google-time {
        font-size: 12px;
        color: rgba(10, 10, 10, 0.55);
      }

      .google-card-logo {
        flex-shrink: 0;
        opacity: 0.85;
      }

      .google-card-text {
        font-size: 14px;
        line-height: 1.6;
        color: rgba(10, 10, 10, 0.78);
      }

      /* ===== COMPARATIVA ===== */
      .compare-section {
        background: linear-gradient(
          180deg,
          var(--gray-900) 0%,
          var(--gray-800) 100%
        );
        color: var(--white);
      }

      .compare-table {
        display: grid;
        grid-template-columns: 1fr 1fr;
        background-color: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 20px;
        overflow: hidden;
      }

      .compare-head {
        padding: 1.5rem 1.25rem;
        font-family: "Poppins", system-ui, sans-serif;
        font-size: 1.25rem;
        font-weight: 500;
        text-align: center;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      }

      .compare-head.amy {
        background: linear-gradient(
          135deg,
          var(--green) 0%,
          var(--green-deep) 100%
        );
        color: var(--gray-900);
      }

      .compare-head.clinica {
        background-color: rgba(255, 255, 255, 0.04);
        color: rgba(255, 255, 255, 0.85);
      }

      .compare-cell {
        padding: 1.1rem 1.25rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        font-size: 14px;
        line-height: 1.5;
        display: flex;
        align-items: flex-start;
        gap: 10px;
      }

      .compare-cell.amy {
        background-color: rgba(168, 213, 162, 0.08);
        color: rgba(255, 255, 255, 0.95);
      }

      .compare-cell.clinica {
        color: rgba(255, 255, 255, 0.55);
      }

      .compare-cell .check,
      .compare-cell .cross {
        flex-shrink: 0;
        width: 22px;
        height: 22px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: 700;
      }

      .compare-cell .check {
        background-color: rgba(168, 213, 162, 0.18);
        color: var(--green);
      }

      .compare-cell .cross {
        background-color: rgba(255, 255, 255, 0.08);
        color: rgba(255, 255, 255, 0.5);
      }

      .compare-row:last-child .compare-cell {
        border-bottom: none;
      }

      .tech-badge {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        margin-top: 2.5rem;
        padding: 14px 24px;
        border-radius: 9999px;
        background: linear-gradient(
          135deg,
          rgba(168, 213, 162, 0.22) 0%,
          rgba(168, 213, 162, 0.06) 100%
        );
        border: 1px solid rgba(168, 213, 162, 0.4);
        color: var(--white);
        font-size: 13px;
        font-weight: 500;
        letter-spacing: 0.04em;
      }

      .tech-badge .tech-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background-color: var(--green);
        box-shadow: 0 0 0 4px rgba(168, 213, 162, 0.25);
      }

      /* ===== SERVICIO ESENCIAL (CARD GRANDE) ===== */
      .esencial-card {
        position: relative;
        display: grid;
        grid-template-columns: 1fr;
        gap: 0;
        background-color: #ffffff;
        border: 1px solid #ececec;
        border-radius: 28px;
        overflow: hidden;
        box-shadow: 0 24px 60px rgba(26, 26, 26, 0.08);
      }

      @media (min-width: 900px) {
        .esencial-card {
          grid-template-columns: 0.95fr 1.05fr;
        }
      }

      .esencial-visual {
        position: relative;
        min-height: 280px;
        background-color: #fafafa;
        overflow: hidden;
      }

      .esencial-visual img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .esencial-icon {
        position: absolute;
        bottom: 1.5rem;
        left: 1.5rem;
        z-index: 2;
        width: 4.25rem;
        height: 4.25rem;
        border-radius: 50%;
        background-color: #ffffff;
        border: 3px solid #ffffff;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .esencial-icon img {
        position: static;
        width: 2.5rem;
        height: 2.5rem;
        object-fit: contain;
      }

      .esencial-body {
        padding: 2rem 1.75rem 2.25rem;
      }

      @media (min-width: 768px) {
        .esencial-body {
          padding: 3rem 2.5rem;
        }
      }

      .esencial-card .price-row {
        display: flex;
        align-items: baseline;
        gap: 12px;
        margin: 1.5rem 0 0.5rem;
      }

      .esencial-card .price-old {
        font-size: 16px;
        color: rgba(10, 10, 10, 0.4);
        text-decoration: line-through;
      }

      .esencial-card .price-new {
        font-family: "Poppins", system-ui, sans-serif;
        font-size: 36px;
        font-weight: 600;
        color: var(--deep-black);
        letter-spacing: -0.01em;
      }

      .esencial-card .price-currency {
        font-size: 12px;
        color: rgba(10, 10, 10, 0.6);
        letter-spacing: 0.1em;
      }

      .esencial-card .duration {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        color: rgba(10, 10, 10, 0.55);
        letter-spacing: 0.05em;
      }

      .esencial-steps-title {
        margin-top: 2rem;
        font-family: "Poppins", system-ui, sans-serif;
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--pale-pink);
      }

      .esencial-steps {
        list-style: none;
        margin: 1rem 0 0;
        padding: 0;
        display: grid;
        grid-template-columns: 1fr;
        gap: 0.85rem;
      }

      @media (min-width: 640px) {
        .esencial-steps {
          grid-template-columns: 1fr 1fr;
          gap: 1rem;
        }
      }

      .esencial-step {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        padding: 12px 14px;
        background-color: var(--green-soft);
        border: 1px solid rgba(168, 213, 162, 0.4);
        border-radius: 14px;
      }

      .esencial-step-num {
        flex-shrink: 0;
        width: 28px;
        height: 28px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: var(--deep-black);
        color: #ffffff;
        font-family: "Poppins", system-ui, sans-serif;
        font-size: 12px;
        font-weight: 600;
      }

      .esencial-step-body {
        flex: 1;
        min-width: 0;
      }

      .esencial-step-title {
        font-family: "Poppins", system-ui, sans-serif;
        font-size: 14px;
        font-weight: 600;
        color: var(--deep-black);
        line-height: 1.2;
      }

      .esencial-step-text {
        margin-top: 4px;
        font-size: 12px;
        line-height: 1.45;
        font-weight: 300;
        color: rgba(10, 10, 10, 0.6);
      }

      .esencial-cta {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        margin-top: 0;
        padding: 16px 24px;
        border-radius: 9999px;
        background-color: var(--deep-black);
        color: #ffffff;
        font-family: "Poppins", system-ui, sans-serif;
        font-size: 13px;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        width: 100%;
        transition:
          background-color 0.3s ease,
          transform 0.3s ease;
      }

      .esencial-cta:hover {
        background-color: var(--whatsapp);
        transform: scale(1.02);
      }

      /* ===== CHECKOUT VISUAL ===== */
      .checkout-visual {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 16px;
        background-color: #f8f9fa;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 14px 24px;
        margin-top: 2rem;
        margin-bottom: 16px;
        width: 100%;
      }

      .checkout-item {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        white-space: nowrap;
      }

      .checkout-check {
        color: var(--green-deep, #7ebc83);
        font-weight: 600;
        font-size: 15px;
        line-height: 1;
      }

      .checkout-label {
        font-family: "Poppins", system-ui, sans-serif;
        font-size: 14px;
        color: #0a0a0a;
        font-weight: 500;
        letter-spacing: 0.01em;
      }

      .checkout-price {
        font-family: "Poppins", system-ui, sans-serif;
        font-size: 15px;
        color: #0a0a0a;
        font-weight: 700;
        letter-spacing: 0.01em;
      }

      .checkout-divider {
        color: #d1d5db;
        font-size: 16px;
        line-height: 1;
        user-select: none;
      }

      .checkout-icon {
        font-size: 14px;
        color: #6b7280;
        line-height: 1;
      }

      @media (max-width: 640px) {
        .checkout-visual {
          flex-wrap: wrap;
          gap: 8px;
          padding: 12px 16px;
        }

        .checkout-label,
        .checkout-price {
          font-size: 13px;
        }

        .checkout-divider {
          font-size: 14px;
        }
      }

      /* ===== SERVICIOS CON PRECIOS ===== */
      .service-price-card {
        position: relative;
        display: flex;
        flex-direction: column;
        background-color: #ffffff;
        border: 1px solid #e8e8e8;
        border-radius: 22px;
        overflow: hidden;
        box-shadow: 0 8px 30px rgba(26, 26, 26, 0.05);
        transition:
          transform 0.35s ease,
          box-shadow 0.35s ease,
          border-color 0.35s ease;
      }

      .service-price-card:hover {
        transform: translateY(-8px);
        border-color: var(--pale-pink);
        box-shadow: 0 24px 50px rgba(26, 26, 26, 0.1);
      }

      .service-price-card.is-popular {
        border-color: var(--green);
        box-shadow: 0 20px 45px rgba(168, 213, 162, 0.3);
      }

      .popular-badge {
        position: absolute;
        top: 18px;
        right: 18px;
        z-index: 3;
        padding: 6px 14px;
        border-radius: 9999px;
        background: linear-gradient(
          135deg,
          var(--green) 0%,
          var(--green-deep) 100%
        );
        color: var(--gray-900);
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        box-shadow: 0 8px 20px rgba(168, 213, 162, 0.5);
      }

      .service-price-card .card-image {
        position: relative;
        height: 180px;
        overflow: hidden;
      }

      .service-price-card .card-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s ease;
      }

      .service-price-card:hover .card-image img {
        transform: scale(1.06);
      }

      .service-price-card .card-icon {
        position: absolute;
        bottom: -1.75rem;
        left: 2rem;
        z-index: 2;
        width: 4.5rem;
        height: 4.5rem;
        border-radius: 50%;
        background-color: #ffffff;
        border: 3px solid #ffffff;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .service-price-card .card-icon img {
        width: 2.5rem;
        height: 2.5rem;
        object-fit: contain;
      }

      .service-price-card .card-body {
        padding: 2.5rem 2rem 2rem;
        display: flex;
        flex-direction: column;
        flex: 1;
      }

      .service-price-card .price-row {
        display: flex;
        align-items: baseline;
        gap: 12px;
        margin: 1.25rem 0 0.5rem;
      }

      .service-price-card .price-old {
        font-size: 16px;
        color: rgba(10, 10, 10, 0.4);
        text-decoration: line-through;
      }

      .service-price-card .price-new {
        font-family: "Poppins", system-ui, sans-serif;
        font-size: 30px;
        font-weight: 600;
        color: var(--deep-black);
        letter-spacing: -0.01em;
      }

      .service-price-card .price-currency {
        font-size: 12px;
        color: rgba(10, 10, 10, 0.6);
        letter-spacing: 0.1em;
      }

      .service-price-card .duration {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        color: rgba(10, 10, 10, 0.55);
        letter-spacing: 0.05em;
      }

      .service-price-card .card-btn {
        margin-top: auto;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 14px 20px;
        border-radius: 9999px;
        background-color: var(--deep-black);
        color: #ffffff;
        font-family: "Poppins", system-ui, sans-serif;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        transition:
          background-color 0.3s ease,
          transform 0.3s ease;
      }

      .service-price-card .card-btn:hover {
        background-color: var(--whatsapp);
        transform: scale(1.02);
      }

      .guarantee-seal {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        padding: 14px 24px;
        border-radius: 9999px;
        background-color: rgba(37, 211, 102, 0.08);
        border: 1px solid rgba(37, 211, 102, 0.25);
        color: var(--whatsapp-dark);
        font-size: 13px;
        font-weight: 500;
      }

      .payment-methods {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: center;
        gap: 10px;
        margin-top: 1.25rem;
      }

      .payment-methods .pm {
        padding: 8px 16px;
        border-radius: 9999px;
        background-color: #ffffff;
        border: 1px solid #e8e8e8;
        font-size: 12px;
        font-weight: 500;
        color: rgba(10, 10, 10, 0.7);
        letter-spacing: 0.04em;
      }

      .payment-methods .pm-sep {
        color: rgba(10, 10, 10, 0.25);
      }

      /* ===== REELS CAROUSEL DE INSTAGRAM ===== */
      .reels-carousel-wrap {
        position: relative;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .reels-track {
        display: flex;
        gap: 1.25rem;
        overflow-x: auto;
        overflow-y: hidden;
        scroll-snap-type: x mandatory;
        scroll-behavior: smooth;
        scrollbar-width: none;
        -ms-overflow-style: none;
        -webkit-overflow-scrolling: touch;
        padding: 1rem 0.25rem 1.5rem;
        flex: 1;
      }

      .reels-track::-webkit-scrollbar {
        display: none;
      }

      .reels-track:focus-visible {
        outline: 2px solid var(--pale-pink);
        outline-offset: 4px;
        border-radius: 12px;
      }

      .reel-card {
        flex: 0 0 86%;
        max-width: 340px;
        scroll-snap-align: center;
        display: flex;
        flex-direction: column;
        background-color: #ffffff;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 8px 30px rgba(26, 26, 26, 0.06);
        transition:
          transform 0.35s ease,
          box-shadow 0.35s ease;
      }

      @media (min-width: 640px) {
        .reel-card {
          flex: 0 0 320px;
        }
      }

      @media (min-width: 1024px) {
        .reel-card {
          flex: 0 0 340px;
        }
      }

      .reel-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 22px 44px rgba(26, 26, 26, 0.1);
      }

      /* Máscara que oculta el header (nombre de cuenta) y footer del embed */
      .reel-mask {
        position: relative;
        width: 100%;
        height: 540px;
        overflow: hidden;
        background-color: #fafafa;
      }

      .reel-mask iframe {
        position: absolute;
        top: -54px;
        left: 0;
        width: 100%;
        height: 660px;
        border: 0;
        background-color: #ffffff;
      }

      @media (min-width: 1024px) {
        .reel-mask {
          height: 560px;
        }
        .reel-mask iframe {
          height: 680px;
        }
      }

      .reel-footer {
        padding: 1.25rem 1.5rem 1.75rem;
        text-align: center;
      }

      .reel-stars {
        color: var(--green-deep);
        font-size: 16px;
        letter-spacing: 4px;
      }

      .reel-text {
        margin-top: 12px;
        font-size: 14px;
        line-height: 1.55;
        font-style: italic;
        color: #1a1a1a;
      }

      /* Flechas */
      .reels-arrow {
        flex-shrink: 0;
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background-color: #ffffff;
        border: 1px solid #e8e8e8;
        color: var(--deep-black);
        display: none;
        align-items: center;
        justify-content: center;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.06);
        cursor: pointer;
        transition:
          transform 0.25s ease,
          background-color 0.25s ease,
          color 0.25s ease,
          opacity 0.25s ease;
        z-index: 4;
      }

      .reels-arrow:hover {
        background-color: var(--deep-black);
        color: #ffffff;
        transform: scale(1.05);
      }

      .reels-arrow:disabled,
      .reels-arrow[aria-disabled="true"] {
        opacity: 0.35;
        cursor: not-allowed;
        background-color: #ffffff;
        color: var(--deep-black);
        transform: none;
      }

      @media (min-width: 768px) {
        .reels-arrow {
          display: inline-flex;
        }
      }

      /* Dots */
      .reels-dots {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 8px;
        margin-top: 1rem;
      }

      .reels-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background-color: rgba(10, 10, 10, 0.18);
        border: none;
        padding: 0;
        cursor: pointer;
        transition:
          width 0.25s ease,
          background-color 0.25s ease;
      }

      .reels-dot.is-active {
        width: 22px;
        border-radius: 9999px;
        background-color: var(--deep-black);
      }

      /* ===== FAQ ===== */
      .faq-item {
        border: 1px solid #e8e8e8;
        border-radius: 12px;
        background-color: #ffffff;
        overflow: hidden;
      }

      .faq-item + .faq-item {
        margin-top: 12px;
      }

      .faq-item summary {
        display: flex;
        cursor: pointer;
        list-style: none;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 20px 24px;
        font-size: 16px;
        font-weight: 500;
        color: #0a0a0a;
      }

      .faq-item summary::-webkit-details-marker {
        display: none;
      }

      .faq-item summary::after {
        content: "+";
        flex-shrink: 0;
        font-size: 22px;
        font-weight: 300;
        color: #1a1a1a;
        transition: transform 0.3s ease;
      }

      .faq-item[open] summary::after {
        transform: rotate(45deg);
      }

      .faq-answer {
        display: grid;
        grid-template-rows: 0fr;
        transition: grid-template-rows 0.35s ease;
      }

      .faq-item[open] .faq-answer {
        grid-template-rows: 1fr;
      }

      .faq-answer-inner {
        overflow: hidden;
      }

      .faq-answer p {
        padding: 0 24px 20px;
        font-size: 15px;
        line-height: 1.65;
        font-weight: 300;
        color: rgba(10, 10, 10, 0.7);
      }

      /* ===== CTA FINAL ===== */
      .cta-final {
        background: linear-gradient(
          135deg,
          var(--gray-900) 0%,
          var(--gray-800) 60%,
          var(--gray-700) 100%
        );
        color: var(--white);
        position: relative;
        overflow: hidden;
      }

      .cta-final::before {
        content: "";
        position: absolute;
        inset: 0;
        background: radial-gradient(
            circle at 20% 20%,
            rgba(168, 213, 162, 0.14) 0%,
            transparent 45%
          ),
          radial-gradient(
            circle at 80% 80%,
            rgba(168, 213, 162, 0.08) 0%,
            transparent 45%
          );
        pointer-events: none;
      }

      .cta-final-logo {
        display: block;
        object-fit: contain;
        border-radius: 16px;
        box-shadow: 0 12px 32px rgba(0, 0, 0, 0.35);
      }

      .cta-final-urgency {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 18px;
        border-radius: 9999px;
        background-color: rgba(168, 213, 162, 0.16);
        border: 1px solid rgba(168, 213, 162, 0.4);
        color: var(--green);
        font-size: 12px;
        font-weight: 500;
        letter-spacing: 0.05em;
      }

      .cta-final-price {
        display: inline-flex;
        align-items: baseline;
        gap: 12px;
        margin-top: 1.5rem;
      }

      .cta-final-price .price-old {
        font-size: 18px;
        color: rgba(255, 255, 255, 0.5);
        text-decoration: line-through;
      }

      .cta-final-price .price-new {
        font-family: "Poppins", system-ui, sans-serif;
        font-size: 36px;
        font-weight: 600;
        color: #ffffff;
      }

      .cta-final-price .price-prefix {
        font-size: 13px;
        color: rgba(255, 255, 255, 0.65);
        letter-spacing: 0.1em;
        text-transform: uppercase;
      }

      .cta-final-price .price-currency {
        font-size: 13px;
        color: rgba(255, 255, 255, 0.75);
        letter-spacing: 0.08em;
      }

      .cta-final-payments {
        margin-top: 1.5rem;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: center;
        gap: 8px;
        color: rgba(255, 255, 255, 0.65);
        font-size: 12px;
      }

      .cta-final-payments .pm {
        padding: 6px 14px;
        border-radius: 9999px;
        background-color: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.12);
        color: rgba(255, 255, 255, 0.85);
        font-weight: 500;
        letter-spacing: 0.04em;
      }

      /* ===== FOOTER ===== */
      .footer-social {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background-color: #f5f5f5;
        color: var(--soft-black);
        transition:
          background-color 0.3s ease,
          color 0.3s ease,
          transform 0.3s ease;
      }

      .footer-social:hover {
        background-color: var(--deep-black);
        color: #ffffff;
        transform: translateY(-2px);
      }

      /* ===== FLOATING WHATSAPP ===== */
      .floating-wa {
        position: fixed;
        right: 1.25rem;
        bottom: 1.25rem;
        z-index: 60;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 3.5rem;
        height: 3.5rem;
        border-radius: 50%;
        background-color: var(--whatsapp);
        color: #ffffff;
        box-shadow: 0 4px 24px rgba(37, 211, 102, 0.45);
        transition:
          transform 0.3s ease,
          box-shadow 0.3s ease;
      }

      .floating-wa::after {
        content: "";
        position: absolute;
        inset: -6px;
        border-radius: 50%;
        border: 2px solid rgba(37, 211, 102, 0.5);
        animation: wa-pulse 2.5s ease-out infinite;
      }

      .floating-wa:hover {
        transform: scale(1.08);
        box-shadow: 0 6px 28px rgba(37, 211, 102, 0.55);
      }

      @keyframes wa-pulse {
        0% {
          transform: scale(0.9);
          opacity: 0.9;
        }
        100% {
          transform: scale(1.5);
          opacity: 0;
        }
      }

      /* ===== NAVBAR ===== */
      #navbar {
        background-color: transparent;
        border-color: transparent;
        transition:
          background-color 0.3s ease,
          border-color 0.3s ease,
          box-shadow 0.3s ease;
      }

      #navbar .nav-logo,
      #navbar .nav-link {
        color: #ffffff;
      }

      #navbar .nav-link {
        opacity: 0.85;
      }

      #navbar .nav-link:hover {
        opacity: 1;
        color: #ffffff;
      }

      #navbar .nav-cta {
        background-color: #ffffff;
        color: var(--deep-black);
      }

      #navbar .nav-cta:hover {
        background-color: var(--whatsapp);
        color: #ffffff;
      }

      #navbar .nav-toggle {
        border-color: rgba(255, 255, 255, 0.4);
      }

      #navbar .nav-toggle-bar {
        background-color: #ffffff;
      }

      #navbar.navbar-scrolled {
        background-color: rgba(255, 255, 255, 0.65);
        backdrop-filter: blur(20px) saturate(160%);
        -webkit-backdrop-filter: blur(20px) saturate(160%);
        border-color: rgba(232, 243, 229, 0.5);
        box-shadow: 0 4px 16px rgba(26, 26, 26, 0.04);
      }

      @media (max-width: 767px) {
        #navbar.navbar-scrolled {
          background-color: rgba(255, 255, 255, 0.55);
          backdrop-filter: blur(22px) saturate(170%);
          -webkit-backdrop-filter: blur(22px) saturate(170%);
          border-color: transparent;
          box-shadow: 0 2px 12px rgba(26, 26, 26, 0.05);
        }

        #navbar.navbar-scrolled nav {
          padding-top: 0.15rem;
          padding-bottom: 0.15rem;
        }
      }

      #navbar.navbar-scrolled .nav-logo,
      #navbar.navbar-scrolled .nav-link {
        color: var(--soft-black);
      }

      #navbar.navbar-scrolled .nav-link {
        opacity: 0.7;
      }

      #navbar.navbar-scrolled .nav-link:hover {
        opacity: 1;
        color: var(--soft-black);
      }

      #navbar.navbar-scrolled .nav-cta {
        background-color: var(--deep-black);
        color: #ffffff;
      }

      #navbar.navbar-scrolled .nav-cta:hover {
        background-color: var(--whatsapp);
      }

      #navbar.navbar-scrolled .nav-toggle {
        border-color: var(--cream);
      }

      #navbar.navbar-scrolled .nav-toggle-bar {
        background-color: var(--soft-black);
      }

      .animate-slide-down {
        animation: slideDown 0.5s ease-out both;
      }

      @keyframes slideDown {
        from {
          opacity: 0;
          transform: translateY(-12px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .nav-open #nav-icon-bar:nth-child(1) {
        transform: translateY(7px) rotate(45deg);
      }
      .nav-open #nav-icon-bar:nth-child(2) {
        opacity: 0;
      }
      .nav-open #nav-icon-bar:nth-child(3) {
        transform: translateY(-7px) rotate(-45deg);
      }

      /* ===== WAVES ===== */
      .wave-divider {
        display: block;
        line-height: 0;
        margin-top: -1px;
      }

      .wave-divider svg {
        display: block;
        width: 100%;
        height: 2.5rem;
      }

      @media (min-width: 768px) {
        .wave-divider svg {
          height: 3.5rem;
        }
      }

      /* ===== HERO TYPOGRAPHY ===== */
      .hero-word {
        display: inline-block;
        will-change: transform, opacity;
      }

      .split-word {
        display: inline-block;
      }

      /* ===== REDUCED MOTION ===== */
      @media (prefers-reduced-motion: reduce) {
        .testimonial-slider-track,
        .hero-scroll-line,
        .floating-wa::after {
          animation: none;
        }

        .faq-answer {
          transition: none;
        }

        .scroll-reveal,
        #hero-title,
        #hero-subtitle,
        #hero-cta,
        #hero-badge,
        #hero-urgency,
        .hero-scroll-indicator {
          opacity: 1 !important;
          transform: none !important;
        }
      }

      @media (min-width: 768px) {
        .floating-wa {
          display: none;
        }
      }

      /* ===== Tailwind overrides ===== */
      h1.font-light,
      h2.font-light,
      .font-display.font-light {
        font-weight: 500;
      }

      h2.font-medium,
      h3.font-medium,
      .font-display.font-medium {
        font-weight: 500;
      }

      .faq-item summary {
        font-family: "Poppins", system-ui, sans-serif;
        font-weight: 500;
        letter-spacing: 0;
        text-transform: none;
      }
    </style>
  </head>

