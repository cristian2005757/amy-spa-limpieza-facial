    <script>
      /* ——— Navbar ——— */
      const toggle = document.getElementById("menu-toggle");
      const menu = document.getElementById("mobile-menu");
      const navbar = document.getElementById("navbar");
      const navLinks = document.querySelectorAll(".mobile-nav-link");

      toggle?.addEventListener("click", () => {
        const isOpen = menu?.classList.toggle("hidden") === false;
        navbar?.classList.toggle("nav-open", isOpen);
        toggle.setAttribute("aria-expanded", String(isOpen));
        toggle.setAttribute("aria-label", isOpen ? "Cerrar menú" : "Abrir menú");
      });

      navLinks.forEach((link) => {
        link.addEventListener("click", () => {
          menu?.classList.add("hidden");
          navbar?.classList.remove("nav-open");
          toggle?.setAttribute("aria-expanded", "false");
          toggle?.setAttribute("aria-label", "Abrir menú");
        });
      });

      const updateNavbar = () => {
        navbar?.classList.toggle("navbar-scrolled", window.scrollY > 50);
      };

      updateNavbar();
      window.addEventListener("scroll", updateNavbar, { passive: true });
    </script>

    <script>
      import { gsap } from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";
      import { SplitText } from "gsap/SplitText";

      document.addEventListener("DOMContentLoaded", () => {
        gsap.registerPlugin(ScrollTrigger, SplitText);

        const prefersReducedMotion = window.matchMedia(
          "(prefers-reduced-motion: reduce)"
        ).matches;

        const easeLuxury = "power2.out";
        const easeHero = "power3.out";

        /** Fallback: restaura visibilidad si GSAP o ScrollTrigger fallan */
        function revealFallback() {
          gsap.set(
            [
              ".scroll-reveal",
              ".gsap-split-title",
              ".service-card",
              "#cta-content",
              "#cta-btn",
              "#footer",
              "#hero-title",
              "#hero-subtitle",
              "#hero-cta",
              "#hero-badge",
              "#hero-urgency",
              ".hero-scroll-indicator",
              ".gallery-item",
              ".editorial-quote",
              "#process-line",
              ".process-badge",
              "#proceso-steps h3",
              "#proceso-steps p",
            ],
            { opacity: 1, y: 0, x: 0, scale: 1, autoAlpha: 1, clearProps: "transform" }
          );
          document.querySelectorAll(".counter").forEach((el) => {
            const target = Number(el.dataset.target) || 0;
            const suffix = el.dataset.suffix || "";
            el.textContent = `${target}${suffix}`;
          });
        }

        function safeSplitText(element, config) {
          if (!element) return null;
          try {
            return SplitText.create(element, config);
          } catch (err) {
            console.warn("[GSAP] SplitText omitido:", element, err);
            return null;
          }
        }

        function scrollReveal(
          targets,
          trigger,
          options = {}
        ) {
          const els = gsap.utils.toArray(targets);
          if (!els.length || !trigger) return;

          gsap.fromTo(
            els,
            { opacity: 0, y: 30 },
            {
              opacity: 1,
              y: 0,
              duration: 0.7,
              ease: easeLuxury,
              stagger: 0.1,
              immediateRender: false,
              ...options,
              scrollTrigger: {
                trigger,
                start: "top 85%",
                toggleActions: "play none none none",
                once: true,
                ...options.scrollTrigger,
              },
            }
          );
        }

        function initHero() {
          const hero = document.querySelector("#hero");
          const video = document.querySelector("#hero-video");
          const overlay = document.querySelector("#hero-overlay");
          const title = document.querySelector("#hero-title");
          const subtitle = document.querySelector("#hero-subtitle");
          const cta = document.querySelector("#hero-cta");
          const badge = document.querySelector("#hero-badge");
          const scrollIndicator = document.querySelector(".hero-scroll-indicator");

          if (!hero) return;

          const tl = gsap.timeline({ defaults: { ease: easeHero } });

          if (overlay) {
            tl.fromTo(overlay, { opacity: 0 }, { opacity: 1, duration: 1.2 }, 0);
          }

          if (video) {
            tl.fromTo(
              video,
              { scale: 1.08 },
              { scale: 1, duration: 2.2, ease: "power2.out" },
              0
            );
          }

          if (title) {
            const split = safeSplitText(title, {
              type: "words",
              wordsClass: "hero-word",
            });

            if (split?.words?.length) {
              tl.fromTo(
                split.words,
                { yPercent: 110, opacity: 0 },
                {
                  yPercent: 0,
                  opacity: 1,
                  duration: 0.95,
                  stagger: 0.07,
                  ease: easeHero,
                },
                0.35
              );
            } else {
              tl.fromTo(
                title,
                { y: 24, opacity: 0 },
                { y: 0, opacity: 1, duration: 0.9 },
                0.35
              );
            }
          }

          if (subtitle) {
            tl.fromTo(
              subtitle,
              { y: 28, opacity: 0 },
              { y: 0, opacity: 1, duration: 0.85 },
              0.75
            );
          }

          if (cta) {
            tl.fromTo(
              cta,
              { y: 20, opacity: 0, scale: 0.96 },
              { y: 0, opacity: 1, scale: 1, duration: 0.75 },
              1
            );
          }

          if (badge) {
            tl.fromTo(
              badge,
              { y: 12, opacity: 0 },
              { y: 0, opacity: 1, duration: 0.7 },
              0.45
            );
          }

          if (scrollIndicator) {
            tl.fromTo(
              scrollIndicator,
              { opacity: 0 },
              { opacity: 1, duration: 0.6 },
              1.35
            );
          }

          if (video) {
            gsap.fromTo(
              video,
              { yPercent: 0 },
              {
                yPercent: 12,
                ease: "none",
                scrollTrigger: {
                  trigger: hero,
                  start: "top top",
                  end: "bottom top",
                  scrub: 1.2,
                },
              }
            );
          }
        }

        function initNavbarEntrance() {
          const navbar = document.querySelector("#navbar");
          if (!navbar) return;

          gsap.fromTo(
            navbar,
            { y: -24, opacity: 0 },
            { y: 0, opacity: 1, duration: 0.9, ease: easeHero, delay: 0.15 }
          );
        }

        function initSectionReveals() {
          document
            .querySelectorAll(
              "#nosotros, #galeria, #servicios, #confianza, #estadisticas, #proceso, #testimonios, #faq"
            )
            .forEach((section) => {
              const reveals = section.querySelectorAll(
                ".scroll-reveal:not(.service-card)"
              );
              scrollReveal(reveals, section);
            });
        }

        function initSplitTitles() {
          document.querySelectorAll(".gsap-split-title").forEach((title) => {
            const section = title.closest("section");
            if (!section) return;

            const split = safeSplitText(title, {
              type: "words",
              wordsClass: "split-word",
            });

            if (!split?.words?.length) return;

            gsap.fromTo(
              split.words,
              { opacity: 0, y: 18 },
              {
                opacity: 1,
                y: 0,
                duration: 0.65,
                stagger: 0.04,
                ease: easeLuxury,
                immediateRender: false,
                scrollTrigger: {
                  trigger: section,
                  start: "top 85%",
                  toggleActions: "play none none none",
                  once: true,
                },
              }
            );
          });
        }

        function initServiceCards() {
          const cards = document.querySelectorAll(".service-card");
          const section = document.querySelector("#servicios");
          if (!cards.length || !section) return;

          gsap.fromTo(
            cards,
            { opacity: 0, y: 36, scale: 0.97 },
            {
              opacity: 1,
              y: 0,
              scale: 1,
              duration: 0.75,
              ease: easeLuxury,
              stagger: 0.12,
              immediateRender: false,
              scrollTrigger: {
                trigger: section,
                start: "top 80%",
                toggleActions: "play none none none",
                once: true,
              },
            }
          );
        }

        function initCounters() {
          document.querySelectorAll(".counter").forEach((counter) => {
            const target = Number(counter.dataset.target) || 0;
            const suffix = counter.dataset.suffix || "";
            const trigger = counter.closest(".scroll-reveal") || counter;
            const obj = { value: 0 };

            gsap.to(obj, {
              value: target,
              duration: 2,
              ease: "power2.out",
              scrollTrigger: {
                trigger,
                start: "top 88%",
                toggleActions: "play none none none",
                once: true,
              },
              onUpdate: () => {
                counter.textContent = `${Math.round(obj.value)}${suffix}`;
              },
            });
          });
        }

        function initProcess() {
          const section = document.querySelector("#proceso");
          const line = document.querySelector("#process-line");
          const steps = document.querySelectorAll("#proceso-steps > li");

          if (!section || !steps.length) return;

          if (line) {
            gsap.fromTo(
              line,
              { scaleX: 0 },
              {
                scaleX: 1,
                duration: 1.2,
                ease: easeLuxury,
                immediateRender: false,
                scrollTrigger: {
                  trigger: section,
                  start: "top 75%",
                  toggleActions: "play none none none",
                  once: true,
                },
              }
            );
          }

          steps.forEach((step) => {
            const badge = step.querySelector(".process-badge");
            const content = step.querySelectorAll("h3, p");

            const tl = gsap.timeline({
              scrollTrigger: {
                trigger: step,
                start: "top 90%",
                toggleActions: "play none none none",
                once: true,
              },
            });

            if (badge) {
              tl.fromTo(
                badge,
                { scale: 0.6, opacity: 0 },
                { scale: 1, opacity: 1, duration: 0.55, ease: "back.out(1.6)" }
              );
            }

            if (content.length) {
              tl.fromTo(
                content,
                { y: 16, opacity: 0 },
                {
                  y: 0,
                  opacity: 1,
                  duration: 0.5,
                  stagger: 0.08,
                  ease: easeLuxury,
                },
                "-=0.25"
              );
            }
          });
        }

        function initCta() {
          const section = document.querySelector("#contacto");
          const block = document.querySelector("#cta-content");
          const btn = document.querySelector("#cta-btn");
          if (!section || !block) return;

          const tl = gsap.timeline({
            scrollTrigger: {
              trigger: section,
              start: "top 82%",
              toggleActions: "play none none none",
              once: true,
            },
          });

          tl.fromTo(
            block,
            { opacity: 0, y: 32 },
            { opacity: 1, y: 0, duration: 0.75, ease: easeLuxury }
          );

          if (btn) {
            tl.fromTo(
              btn,
              { scale: 0.9, opacity: 0 },
              { scale: 1, opacity: 1, duration: 0.55, ease: "back.out(1.4)" },
              "-=0.35"
            );
          }
        }

        function initFooter() {
          const footer = document.querySelector("#footer");
          if (!footer) return;

          gsap.fromTo(
            footer,
            { opacity: 0, y: 24 },
            {
              opacity: 1,
              y: 0,
              duration: 0.7,
              ease: easeLuxury,
              immediateRender: false,
              scrollTrigger: {
                trigger: footer,
                start: "top 95%",
                toggleActions: "play none none none",
                once: true,
              },
            }
          );
        }

        function initAnimations() {
          gsap.set("#hero-subtitle, #hero-cta, #hero-badge, .hero-scroll-indicator", {
            autoAlpha: 0,
          });
          gsap.set(".scroll-reveal", { opacity: 0, y: 30 });

          if (prefersReducedMotion) {
            revealFallback();
            return;
          }

          try {
            initHero();
            initNavbarEntrance();
            initSectionReveals();
            initSplitTitles();
            initServiceCards();
            initCounters();
            initProcess();
            initCta();
            initFooter();

            ScrollTrigger.refresh();

            window.addEventListener("load", () => {
              ScrollTrigger.refresh();
            });
          } catch (err) {
            console.error("[GSAP] Error al inicializar animaciones:", err);
            revealFallback();
          }
        }

        initAnimations();

        /* Si tras 2.5s algo sigue invisible, forzar fallback */
        setTimeout(() => {
          const selectors =
            ".scroll-reveal, .service-card, #cta-content, .gsap-split-title";
          const stuck = [...document.querySelectorAll(selectors)].some(
            (el) => parseFloat(getComputedStyle(el).opacity) < 0.05
          );
          if (stuck) {
            console.warn("[GSAP] Fallback de visibilidad activado");
            revealFallback();
            ScrollTrigger.refresh();
          }
        }, 2500);
      });
    </script>
  </body>
</html>
