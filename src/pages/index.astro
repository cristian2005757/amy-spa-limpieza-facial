---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Esencial — Limpieza facial profesional que transforma y renueva tu piel."
    />
    <meta name="generator" content={Astro.generator} />
    <title>Esencial | Limpieza Facial Profesional</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=DM+Sans:wght@300;400;500&display=swap"
      rel="stylesheet"
    />

    <style is:global>
      @import "tailwindcss";

      :root {
        --cream: #f5f0eb;
        --pale-pink: #e8c4b8;
        --soft-black: #1a1a1a;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: "DM Sans", system-ui, sans-serif;
        font-weight: 300;
        color: var(--soft-black);
        background-color: #ffffff;
      }

      h1,
      h2 {
        font-family: "Playfair Display", Georgia, serif;
        font-weight: 500;
        letter-spacing: -0.02em;
      }

      .font-display {
        font-family: "Playfair Display", Georgia, serif;
        font-weight: 500;
        letter-spacing: -0.02em;
      }

      .nav-logo {
        font-family: "Playfair Display", Georgia, serif;
        font-style: italic;
        font-weight: 400;
        letter-spacing: 0;
      }

      p,
      li,
      blockquote,
      .faq-answer p,
      .testimonial-card-slide .quote-text {
        font-family: "DM Sans", system-ui, sans-serif;
        font-weight: 300;
      }

      .section-whatsapp-cta,
      .nav-cta,
      #hero-cta a,
      .service-card-btn,
      #cta-btn,
      .nav-link,
      .mobile-nav-link,
      #mobile-menu a.rounded-full {
        font-family: "DM Sans", system-ui, sans-serif;
        font-weight: 500;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .testimonial-card-slide .author {
        font-family: "DM Sans", system-ui, sans-serif;
        font-weight: 500;
        text-transform: none;
        letter-spacing: 0;
      }

      @keyframes fadeInUp {
        from {
          opacity: 0;
          transform: translateY(28px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      @keyframes fadeIn {
        from {
          opacity: 0;
        }
        to {
          opacity: 1;
        }
      }

      @keyframes slideDown {
        from {
          opacity: 0;
          transform: translateY(-12px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .hero-word {
        display: inline-block;
        will-change: transform, opacity;
      }

      .split-word {
        display: inline-block;
      }

      #process-line {
        transform-origin: left center;
      }

      .testimonial-slider-wrap {
        overflow: hidden;
        width: 100%;
        mask-image: linear-gradient(
          to right,
          transparent 0%,
          black 15%,
          black 85%,
          transparent 100%
        );
        -webkit-mask-image: linear-gradient(
          to right,
          transparent 0%,
          black 15%,
          black 85%,
          transparent 100%
        );
      }

      .testimonial-slider-wrap:hover .testimonial-slider-track {
        animation-play-state: paused;
      }

      .testimonial-slider-track {
        display: flex;
        width: max-content;
        gap: 24px;
        animation: testimonial-slide 30s linear infinite;
        will-change: transform;
      }

      @keyframes testimonial-slide {
        0% {
          transform: translateX(0);
        }
        100% {
          transform: translateX(calc(-380px * 6 - 24px * 6));
        }
      }

      .testimonial-card-slide {
        flex-shrink: 0;
        width: 380px;
        padding: 28px;
        background-color: #ffffff;
        border: 1px solid #e8e8e8;
        border-radius: 16px;
        box-shadow: 0 2px 20px rgba(0, 0, 0, 0.06);
      }

      .testimonial-card-slide .quote-mark {
        font-family: "Playfair Display", Georgia, serif;
        font-size: 80px;
        line-height: 0.7;
        color: #e8e8e8;
        user-select: none;
      }

      .testimonial-card-slide .quote-text {
        margin-top: 8px;
        font-size: 16px;
        line-height: 1.6;
        font-style: italic;
        color: #0a0a0a;
      }

      .testimonial-card-slide .stars {
        margin-top: 20px;
        font-size: 14px;
        letter-spacing: 2px;
      }

      .testimonial-card-slide .author-row {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-top: 20px;
      }

      .section-label {
        font-family: "DM Sans", system-ui, sans-serif;
        font-size: 11px;
        font-weight: 500;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: #e8c4b8;
      }

      .hero-gradient {
        background: linear-gradient(
          to bottom,
          rgba(0, 0, 0, 0.25) 0%,
          rgba(0, 0, 0, 0.45) 50%,
          rgba(0, 0, 0, 0.65) 100%
        );
      }

      .hero-glass-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border-radius: 9999px;
        border: 1px solid rgba(255, 255, 255, 0.35);
        background: rgba(255, 255, 255, 0.12);
        padding: 10px 20px;
        font-size: 13px;
        color: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
      }

      .hero-scroll-indicator {
        position: absolute;
        bottom: 2rem;
        left: 50%;
        z-index: 10;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        transform: translateX(-50%);
        color: rgba(255, 255, 255, 0.7);
        font-size: 11px;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        transition: color 0.3s ease;
      }

      .hero-scroll-indicator:hover {
        color: #ffffff;
      }

      .hero-scroll-line {
        display: block;
        width: 1px;
        height: 40px;
        background: linear-gradient(to bottom, rgba(255, 255, 255, 0.8), transparent);
        animation: scroll-pulse 2s ease-in-out infinite;
      }

      @keyframes scroll-pulse {
        0%,
        100% {
          transform: scaleY(1);
          opacity: 0.6;
        }
        50% {
          transform: scaleY(0.6);
          opacity: 1;
        }
      }

      .editorial-quote {
        background: linear-gradient(135deg, #f5f0eb 0%, #ffffff 50%, #f5f0eb 100%);
        padding: 4rem 1.5rem;
        text-align: center;
      }

      .editorial-quote p {
        font-family: "Playfair Display", Georgia, serif;
        font-size: clamp(1.5rem, 4vw, 2.25rem);
        font-weight: 500;
        font-style: italic;
        line-height: 1.4;
        letter-spacing: -0.02em;
        color: #1a1a1a;
      }

      .gallery-grid {
        display: grid;
        gap: 1rem;
        grid-template-columns: 1fr;
        grid-template-rows: auto;
      }

      @media (min-width: 768px) {
        .gallery-grid {
          grid-template-columns: 1.2fr 1fr;
          grid-template-rows: 200px 200px;
          gap: 1rem;
        }

        .gallery-item-main {
          grid-row: span 2;
          min-height: 416px;
        }
      }

      .gallery-item {
        position: relative;
        overflow: hidden;
        border-radius: 20px;
        box-shadow: 0 8px 40px rgba(26, 26, 26, 0.08);
      }

      .gallery-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s ease;
      }

      .gallery-item:hover img {
        transform: scale(1.05);
      }

      .icon-circle {
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        background-color: #f5f0eb;
        transition: transform 0.3s ease;
      }

      .service-card:hover .icon-circle {
        transform: scale(1.08);
      }

      .service-card-visual {
        position: relative;
        height: 10rem;
        overflow: hidden;
      }

      .service-card-visual > img:first-child {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s ease;
      }

      .service-card:hover .service-card-visual > img:first-child {
        transform: scale(1.06);
      }

      .service-card-icon-wrap {
        position: absolute;
        bottom: -1.75rem;
        left: 2rem;
        z-index: 2;
      }

      .service-card-icon-wrap .icon-circle {
        width: 4.5rem;
        height: 4.5rem;
        border: 3px solid #ffffff;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
      }

      .service-card-icon-wrap img {
        width: 2.5rem;
        height: 2.5rem;
        object-fit: contain;
      }

      .service-card-body {
        padding: 2.5rem 2rem 2rem;
      }

      .process-step-img {
        position: relative;
        margin-bottom: 1rem;
      }

      .process-step-img img {
        width: 5rem;
        height: 5rem;
        border-radius: 50%;
        object-fit: cover;
        border: 3px solid #f5f0eb;
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
      }

      .process-step-img .process-badge {
        position: absolute;
        right: calc(50% - 3.5rem);
        bottom: -4px;
        width: 2rem;
        height: 2rem;
        font-size: 0.875rem;
        background-color: #e8c4b8 !important;
        color: #1a1a1a !important;
      }

      .counter-wrap .counter-line {
        display: block;
        width: 48px;
        height: 2px;
        margin: 12px auto 0;
        background-color: #e8c4b8;
      }

      .cta-visual-bg {
        position: absolute;
        inset: 0;
        z-index: 0;
        object-fit: cover;
        width: 100%;
        height: 100%;
      }

      .cta-visual-overlay {
        position: absolute;
        inset: 0;
        z-index: 1;
        background: linear-gradient(
          135deg,
          rgba(232, 196, 184, 0.92) 0%,
          rgba(245, 240, 235, 0.88) 100%
        );
      }

      .floating-wa {
        position: fixed;
        right: 1.25rem;
        bottom: 1.25rem;
        z-index: 60;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 3.5rem;
        height: 3.5rem;
        border-radius: 50%;
        background-color: #25d366;
        color: #ffffff;
        box-shadow: 0 4px 24px rgba(37, 211, 102, 0.45);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
      }

      .floating-wa:hover {
        transform: scale(1.08);
        box-shadow: 0 6px 28px rgba(37, 211, 102, 0.55);
      }

      .testimonial-avatar {
        width: 72px;
        height: 72px;
        flex-shrink: 0;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid #f5f0eb;
      }

      .testimonial-avatar-initial {
        display: flex;
        width: 72px;
        height: 72px;
        flex-shrink: 0;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        background-color: #f5f0eb;
        font-family: "Playfair Display", Georgia, serif;
        font-size: 22px;
        font-weight: 500;
        color: #1a1a1a;
      }

      .testimonial-card-slide .author {
        font-size: 15px;
        color: #0a0a0a;
      }

      .section-whatsapp-cta {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        border-radius: 9999px;
        background-color: #1a1a1a;
        padding: 14px 28px;
        font-size: 12px;
        color: #ffffff;
        transition: transform 0.3s ease, background-color 0.3s ease;
      }

      .section-whatsapp-cta:hover {
        transform: scale(1.02);
        background-color: rgba(26, 26, 26, 0.9);
      }

      .faq-item {
        border: 1px solid #e8e8e8;
        border-radius: 12px;
        background-color: #ffffff;
        overflow: hidden;
      }

      .faq-item + .faq-item {
        margin-top: 12px;
      }

      .faq-item summary {
        display: flex;
        cursor: pointer;
        list-style: none;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding: 20px 24px;
        font-size: 16px;
        font-weight: 500;
        color: #0a0a0a;
      }

      .faq-item summary::-webkit-details-marker {
        display: none;
      }

      .faq-item summary::after {
        content: "+";
        flex-shrink: 0;
        font-size: 22px;
        font-weight: 300;
        color: #1a1a1a;
        transition: transform 0.3s ease;
      }

      .faq-item[open] summary::after {
        transform: rotate(45deg);
      }

      .faq-answer {
        display: grid;
        grid-template-rows: 0fr;
        transition: grid-template-rows 0.35s ease;
      }

      .faq-item[open] .faq-answer {
        grid-template-rows: 1fr;
      }

      .faq-answer-inner {
        overflow: hidden;
      }

      .faq-answer p {
        padding: 0 24px 20px;
        font-size: 15px;
        line-height: 1.65;
        font-weight: 300;
        color: rgba(10, 10, 10, 0.7);
      }

      @media (prefers-reduced-motion: reduce) {
        .testimonial-slider-track {
          animation: none;
        }

        .faq-answer {
          transition: none;
        }

        .hero-scroll-line {
          animation: none;
        }
      }

      @media (min-width: 768px) {
        .floating-wa {
          display: none;
        }
      }

      .wave-divider {
        display: block;
        line-height: 0;
        margin-top: -1px;
      }

      .wave-divider svg {
        display: block;
        width: 100%;
        height: 2.5rem;
      }

      @media (min-width: 768px) {
        .wave-divider svg {
          height: 3.5rem;
        }
      }

      .service-card {
        border: 1px solid transparent;
        transition:
          transform 0.3s ease,
          box-shadow 0.3s ease,
          border-color 0.3s ease;
      }

      .service-card:hover {
        transform: translateY(-8px);
        border-color: #e8c4b8;
        box-shadow:
          0 20px 25px -5px rgba(26, 26, 26, 0.08),
          0 8px 10px -6px rgba(26, 26, 26, 0.04);
      }

      .service-card-btn {
        transition:
          background-color 0.3s ease,
          color 0.3s ease,
          border-color 0.3s ease;
      }

      .service-card:hover .service-card-btn {
        background-color: #1a1a1a;
        border-color: #1a1a1a;
        color: #ffffff;
      }

      #navbar {
        background-color: transparent;
        border-color: transparent;
        transition:
          background-color 0.3s ease,
          border-color 0.3s ease,
          box-shadow 0.3s ease;
      }

      #navbar .nav-logo,
      #navbar .nav-link {
        color: #ffffff;
      }

      #navbar .nav-link {
        opacity: 0.85;
      }

      #navbar .nav-link:hover {
        opacity: 1;
        color: #ffffff;
      }

      #navbar .nav-cta {
        background-color: #ffffff;
        color: #1a1a1a;
      }

      #navbar .nav-cta:hover {
        background-color: rgba(255, 255, 255, 0.9);
      }

      #navbar .nav-toggle {
        border-color: rgba(255, 255, 255, 0.4);
      }

      #navbar .nav-toggle-bar {
        background-color: #ffffff;
      }

      #navbar.navbar-scrolled {
        background-color: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(12px);
        border-color: rgba(245, 240, 235, 0.8);
        box-shadow: 0 1px 3px rgba(26, 26, 26, 0.06);
      }

      #navbar.navbar-scrolled .nav-logo,
      #navbar.navbar-scrolled .nav-link {
        color: #1a1a1a;
      }

      #navbar.navbar-scrolled .nav-link {
        opacity: 0.7;
      }

      #navbar.navbar-scrolled .nav-link:hover {
        opacity: 1;
        color: #1a1a1a;
      }

      #navbar.navbar-scrolled .nav-cta {
        background-color: #1a1a1a;
        color: #ffffff;
      }

      #navbar.navbar-scrolled .nav-cta:hover {
        background-color: rgba(26, 26, 26, 0.85);
      }

      #navbar.navbar-scrolled .nav-toggle {
        border-color: #f5f0eb;
      }

      #navbar.navbar-scrolled .nav-toggle-bar {
        background-color: #1a1a1a;
      }

      .animate-fade-in {
        animation: fadeIn 0.8s ease-out both;
      }

      .animate-slide-down {
        animation: slideDown 0.5s ease-out both;
      }

      .nav-open #nav-icon-bar:nth-child(1) {
        transform: translateY(7px) rotate(45deg);
      }
      .nav-open #nav-icon-bar:nth-child(2) {
        opacity: 0;
      }
      .nav-open #nav-icon-bar:nth-child(3) {
        transform: translateY(-7px) rotate(-45deg);
      }

      @media (prefers-reduced-motion: reduce) {
        .scroll-reveal,
        #hero-title,
        #hero-subtitle,
        #hero-cta,
        #hero-badge,
        #hero-urgency,
        .hero-scroll-indicator {
          opacity: 1 !important;
          transform: none !important;
        }
      }

      /* Overrides Tailwind utilities en títulos */
      h1.font-light,
      h2.font-light,
      .font-display.font-light {
        font-weight: 500;
      }

      h2.font-medium,
      h3.font-medium,
      .font-display.font-medium {
        font-weight: 500;
      }

      .counter.font-display {
        font-weight: 500;
      }

      .faq-item summary {
        font-family: "DM Sans", system-ui, sans-serif;
        font-weight: 500;
        letter-spacing: 0;
        text-transform: none;
      }
    </style>
  </head>

  <body class="antialiased text-[#1A1A1A]">
    <!-- 1. NAVBAR -->
    <header
      id="navbar"
      class="fixed top-0 left-0 right-0 z-50 border-b transition-all duration-300"
    >
      <nav
        class="mx-auto flex max-w-6xl items-center justify-between px-5 py-4 md:px-8"
        aria-label="Principal"
      >
        <a
          href="#"
          class="nav-logo text-2xl transition-colors duration-300 md:text-3xl"
        >
          Esencial
        </a>

        <ul
          class="hidden items-center gap-8 text-sm font-medium tracking-wide uppercase md:flex"
        >
          <li>
            <a
              href="#servicios"
              class="nav-link transition-colors duration-300"
              >Servicios</a
            >
          </li>
          <li>
            <a
              href="#nosotros"
              class="nav-link transition-colors duration-300"
              >Nosotros</a
            >
          </li>
          <li>
            <a
              href="#contacto"
              class="nav-link transition-colors duration-300"
              >Contacto</a
            >
          </li>
        </ul>

        <div class="flex items-center gap-3">
          <a
            href={WA_LINK}
            target="_blank"
            rel="noopener noreferrer"
            class="nav-cta hidden rounded-full px-6 py-2.5 text-xs font-medium tracking-widest uppercase transition-all duration-300 md:inline-block"
          >
            Reservar
          </a>

          <button
            id="menu-toggle"
            type="button"
            class="nav-toggle relative flex h-10 w-10 flex-col items-center justify-center gap-1.5 rounded-full border transition-colors duration-300 md:hidden"
            aria-label="Abrir menú"
            aria-expanded="false"
            aria-controls="mobile-menu"
          >
            <span
              id="nav-icon-bar"
              class="nav-toggle-bar block h-0.5 w-5 transition-all duration-300"
            ></span>
            <span
              id="nav-icon-bar"
              class="nav-toggle-bar block h-0.5 w-5 transition-all duration-300"
            ></span>
            <span
              id="nav-icon-bar"
              class="nav-toggle-bar block h-0.5 w-5 transition-all duration-300"
            ></span>
          </button>
        </div>
      </nav>

      <div
        id="mobile-menu"
        class="hidden border-t border-[#F5F0EB] bg-white px-5 pb-6 md:hidden animate-slide-down"
      >
        <ul class="flex flex-col gap-1 pt-4 text-center">
          <li>
            <a
              href="#servicios"
              class="mobile-nav-link block py-3 text-sm font-medium tracking-wide uppercase text-[#1A1A1A]/80"
              >Servicios</a
            >
          </li>
          <li>
            <a
              href="#nosotros"
              class="mobile-nav-link block py-3 text-sm font-medium tracking-wide uppercase text-[#1A1A1A]/80"
              >Nosotros</a
            >
          </li>
          <li>
            <a
              href="#contacto"
              class="mobile-nav-link block py-3 text-sm font-medium tracking-wide uppercase text-[#1A1A1A]/80"
              >Contacto</a
            >
          </li>
          <li class="pt-2">
            <a
              href={WA_LINK}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block w-full rounded-full bg-[#1A1A1A] px-6 py-3 text-xs font-medium tracking-widest text-white uppercase"
            >
              Reservar
            </a>
          </li>
        </ul>
      </div>
    </header>

    <main>
      <!-- 2. HERO (video de fondo) -->
      <section
        id="hero"
        class="relative h-screen min-h-[100vh] w-full overflow-hidden"
        aria-label="Presentación"
      >
        <video
          id="hero-video"
          class="absolute inset-0 z-0 h-full w-full object-cover"
          autoplay
          muted
          loop
          playsinline
          poster="/imagenes/ambiente-spa.png"
          aria-hidden="true"
        >
          <source src="/videos/facial.mp4" type="video/mp4" />
        </video>

        <div id="hero-overlay" class="hero-gradient absolute inset-0 z-[1]" aria-hidden="true"></div>

        <div
          class="relative z-10 flex h-full min-h-[100vh] items-center justify-center px-5 md:px-8"
        >
          <div class="mx-auto max-w-4xl text-center">
            <div id="hero-badge" class="hero-glass-badge mb-8">
              <span aria-hidden="true">⭐⭐⭐⭐⭐</span>
              <span class="font-medium">4.9</span>
              <span class="opacity-70">|</span>
              <span>+200 clientas satisfechas</span>
            </div>
            <h1
              id="hero-title"
              class="font-display text-4xl leading-tight font-light text-white sm:text-5xl md:text-6xl lg:text-7xl"
            >
              Tu piel merece lo
              <em class="font-normal italic text-[#E8C4B8]">esencial</em>
            </h1>
            <p
              id="hero-subtitle"
              class="mx-auto mt-6 max-w-2xl text-base leading-relaxed font-light text-white/90 md:text-lg"
            >
              Limpieza facial profesional que transforma y renueva tu piel desde
              adentro
            </p>
            <div id="hero-cta" class="mt-10">
              <a
                href={WA_URL}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 rounded-full bg-white px-8 py-4 text-sm font-medium tracking-widest text-[#1A1A1A] uppercase transition-all hover:scale-[1.02] hover:bg-white/90 hover:shadow-lg"
              >
                <span>Agendar Cita</span>
                <span aria-hidden="true">→</span>
              </a>
              <p id="hero-urgency" class="mt-4 text-sm text-white/80">
                Solo 8 citas disponibles esta semana
              </p>
            </div>
          </div>
        </div>

        <a href="#nosotros" class="hero-scroll-indicator" aria-label="Desplazarse hacia abajo">
          <span>Descubre</span>
          <span class="hero-scroll-line" aria-hidden="true"></span>
        </a>
      </section>

      <!-- Ola: Hero → Nosotros -->
      <div class="wave-divider" aria-hidden="true">
        <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
          <path
            fill="#ffffff"
            d="M0,48 C240,72 480,24 720,48 C960,72 1200,24 1440,48 L1440,80 L0,80 Z"
          ></path>
        </svg>
      </div>

      <!-- 3. SOBRE NOSOTROS -->
      <section
        id="nosotros"
        class="bg-white px-5 py-20 md:px-8 md:py-28"
      >
        <div class="mx-auto max-w-6xl">
          <div
            class="grid grid-cols-1 items-center gap-10 md:grid-cols-2 md:gap-14"
          >
            <div>
              <p class="section-label">Nosotros</p>
              <h2
                class="gsap-split-title font-display mt-2 text-3xl font-light text-[#1A1A1A] md:text-5xl"
              >
                ¿Qué es Esencial?
              </h2>
              <p class="scroll-reveal mt-6 text-base leading-relaxed font-light text-[#1A1A1A]/70 md:text-lg">
                Somos un espacio dedicado a la salud y belleza de tu piel. Ofrecemos
                tratamientos faciales profesionales con productos de alta calidad,
                técnicas especializadas y un enfoque personalizado que respeta la
                naturaleza de cada tipo de piel.
              </p>
            </div>
            <div class="scroll-reveal">
              <img
                src="/imagenes/ambiente-spa.png"
                alt="Ambiente spa de Esencial — espacio tranquilo y premium"
                width="600"
                height="450"
                class="h-auto w-full rounded-[20px] object-cover shadow-[0_8px_40px_rgba(26,26,26,0.08)]"
                loading="lazy"
              />
            </div>
          </div>

          <div
            class="mt-16 grid grid-cols-1 gap-8 sm:grid-cols-3 sm:gap-6 md:mt-20 md:gap-10"
          >
            {
              valores.map((item, i) => (
                <div
                  class="scroll-reveal flex flex-col items-center rounded-2xl border border-[#F5F0EB] bg-[#F5F0EB]/30 px-6 py-10 text-center transition-shadow hover:shadow-md"
                  data-delay={`${i * 0.1}`}
                >
                  <div class="icon-circle h-16 w-16">
                    <img
                      src={item.icon}
                      alt=""
                      width="40"
                      height="40"
                      class="h-10 w-10 object-contain"
                      loading="lazy"
                    />
                  </div>
                  <h3 class="font-display mt-4 text-2xl font-medium">{item.title}</h3>
                  <p class="mt-3 text-sm leading-relaxed font-light text-[#1A1A1A]/65">
                    {item.text}
                  </p>
                </div>
              ))
            }
          </div>
        </div>
      </section>

      <!-- Frase editorial -->
      <div class="editorial-quote scroll-reveal" aria-hidden="true">
        <p>Cuidado facial con alma de spa, precisión de clínica.</p>
      </div>

      <!-- Galería editorial -->
      <section id="galeria" class="bg-white px-5 py-16 md:px-8 md:py-20" aria-label="Galería">
        <div class="mx-auto max-w-6xl">
          <p class="section-label text-center">Experiencia Esencial</p>
          <div class="gallery-grid mt-8">
            <div class="gallery-item gallery-item-main scroll-reveal h-64 md:h-auto">
              <img
                src="/imagenes/ambiente-spa.png"
                alt="Espacio de tratamiento Esencial"
                loading="lazy"
              />
            </div>
            <div class="gallery-item scroll-reveal h-48 md:h-auto" data-delay="0.1">
              <img
                src="/imagenes/tratamiento.png"
                alt="Tratamiento facial profesional"
                loading="lazy"
              />
            </div>
            <div class="gallery-item scroll-reveal h-48 md:h-auto" data-delay="0.2">
              <img
                src="/imagenes/mujer.png"
                alt="Clienta satisfecha"
                loading="lazy"
              />
            </div>
          </div>
        </div>
      </section>

      <!-- Ola: Galería → Servicios -->
      <div class="wave-divider" aria-hidden="true">
        <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
          <path
            fill="#FAF7F4"
            d="M0,40 C360,8 720,64 1080,32 1440,48 L1440,80 L0,80 Z"
          ></path>
        </svg>
      </div>

      <!-- 4. SERVICIOS -->
      <section
        id="servicios"
        class="bg-[#F5F0EB]/40 px-5 py-20 md:px-8 md:py-28"
      >
        <div class="mx-auto max-w-6xl">
          <div class="text-center">
            <p class="section-label scroll-reveal">Tratamientos</p>
            <h2
              class="gsap-split-title font-display mt-2 text-3xl font-light text-[#1A1A1A] md:text-5xl"
            >
              Servicios
            </h2>
          </div>

          <div class="mt-14 grid grid-cols-1 gap-8 md:grid-cols-3 md:gap-6 lg:gap-8">
            {
              services.map((service, i) => (
                <article
                  class:list={[
                    "service-card group flex flex-col overflow-hidden rounded-2xl bg-white shadow-[0_8px_30px_rgba(26,26,26,0.06)]",
                    i === 1 && "md:-mt-2",
                  ]}
                >
                  <div class="service-card-visual">
                    <img
                      src={service.image}
                      alt=""
                      loading="lazy"
                    />
                    <div class="service-card-icon-wrap">
                      <div class="icon-circle">
                        <img
                          src={service.icon}
                          alt=""
                          width="40"
                          height="40"
                          loading="lazy"
                        />
                      </div>
                    </div>
                  </div>
                  <div class="service-card-body flex flex-1 flex-col">
                    <h3 class="font-display text-2xl font-medium text-[#1A1A1A]">
                      {service.title}
                    </h3>
                    <p class="mt-3 flex-1 text-sm leading-relaxed font-light text-[#1A1A1A]/65">
                      {service.description}
                    </p>
                    <a
                      href={WA_LINK}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="service-card-btn mt-8 inline-block w-full rounded-full border border-[#1A1A1A] py-3 text-center text-xs"
                    >
                      Reservar
                    </a>
                  </div>
                </article>
              ))
            }
          </div>

          <div class="scroll-reveal mt-14 text-center">
            <a
              href={WA_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="section-whatsapp-cta"
            >
              Reservar por WhatsApp
            </a>
          </div>
        </div>
      </section>

      <!-- Ola: Servicios → Confianza -->
      <div class="wave-divider" aria-hidden="true">
        <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
          <path
            fill="#F8F9FA"
            d="M0,40 C360,8 720,64 1080,32 1440,48 L1440,80 L0,80 Z"
          ></path>
        </svg>
      </div>

      <!-- 4c. CONFIANZA -->
      <section
        id="confianza"
        class="bg-[#F8F9FA] px-5 py-20 md:px-8 md:py-28"
      >
        <div class="mx-auto max-w-6xl">
          <div class="text-center">
            <p class="section-label scroll-reveal">Confianza</p>
            <h2
              class="gsap-split-title font-display mt-2 text-3xl font-light text-[#1A1A1A] md:text-5xl"
            >
              ¿Por qué elegirnos?
            </h2>
          </div>

          <div class="mt-14 grid grid-cols-1 gap-10 md:grid-cols-3 md:gap-8">
            {
              confianzaItems.map((item, i) => (
                <div
                  class="scroll-reveal flex flex-col items-center rounded-2xl border border-[#E8E8E8] bg-white px-6 py-10 text-center shadow-[0_2px_20px_rgba(0,0,0,0.04)]"
                  data-delay={`${i * 0.1}`}
                >
                  <div class="icon-circle h-20 w-20">
                    <img
                      src={item.icon}
                      alt=""
                      width="48"
                      height="48"
                      class="h-12 w-12 object-contain"
                      loading="lazy"
                    />
                  </div>
                  <h3 class="font-display mt-5 text-xl font-medium text-[#0A0A0A]">
                    {item.title}
                  </h3>
                  <p class="mt-3 text-sm leading-relaxed font-light text-[#0A0A0A]/65">
                    {item.text}
                  </p>
                </div>
              ))
            }
          </div>

          <div class="scroll-reveal mt-14 text-center">
            <a
              href={WA_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="section-whatsapp-cta"
            >
              Reservar por WhatsApp
            </a>
          </div>
        </div>
      </section>

      <!-- Ola: Confianza → Contadores -->
      <div class="wave-divider" aria-hidden="true">
        <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
          <path
            fill="#F5F0EB"
            d="M0,32 C320,64 640,16 960,40 C1280,64 1440,24 1440,48 L1440,80 L0,80 Z"
          ></path>
        </svg>
      </div>

      <!-- 4b. CONTADORES -->
      <section
        id="estadisticas"
        class="bg-[#F5F0EB] px-5 py-16 md:px-8 md:py-24"
        aria-label="Estadísticas"
      >
        <div class="mx-auto max-w-6xl">
          <div class="grid grid-cols-1 gap-12 sm:grid-cols-3 sm:gap-8">
            <div class="counter-wrap scroll-reveal text-center" data-delay="0">
              <p
                class="counter font-display text-5xl font-light text-[#1A1A1A] md:text-6xl"
                data-target="500"
                data-suffix="+"
              >
                0
              </p>
              <span class="counter-line" aria-hidden="true"></span>
              <p class="mt-3 text-sm font-light text-[#1A1A1A]/55 md:text-base">
                Clientas satisfechas
              </p>
            </div>
            <div class="counter-wrap scroll-reveal text-center" data-delay="0.1">
              <p
                class="counter font-display text-5xl font-light text-[#1A1A1A] md:text-6xl"
                data-target="3"
                data-suffix="+"
              >
                0
              </p>
              <span class="counter-line" aria-hidden="true"></span>
              <p class="mt-3 text-sm font-light text-[#1A1A1A]/55 md:text-base">
                Años de experiencia
              </p>
            </div>
            <div class="counter-wrap scroll-reveal text-center" data-delay="0.2">
              <p
                class="counter font-display text-5xl font-light text-[#1A1A1A] md:text-6xl"
                data-target="100"
                data-suffix="%"
              >
                0
              </p>
              <span class="counter-line" aria-hidden="true"></span>
              <p class="mt-3 text-sm font-light text-[#1A1A1A]/55 md:text-base">
                Productos naturales
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- Ola: Contadores → Proceso -->
      <div class="wave-divider" aria-hidden="true">
        <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
          <path
            fill="#ffffff"
            d="M0,48 C360,16 720,64 1080,32 1440,48 L1440,80 L0,80 Z"
          ></path>
        </svg>
      </div>

      <!-- 5. PROCESO -->
      <section id="proceso" class="bg-white px-5 py-20 md:px-8 md:py-28">
        <div class="mx-auto max-w-6xl">
          <div class="text-center">
            <p class="section-label scroll-reveal">Experiencia</p>
            <h2
              class="gsap-split-title font-display mt-2 text-3xl font-light text-[#1A1A1A] md:text-5xl"
            >
              Tu experiencia, paso a paso
            </h2>
            <p class="scroll-reveal mt-4 text-sm font-light text-[#1A1A1A]/60 md:text-base">
              Un ritual cuidadoso diseñado para tu bienestar
            </p>
          </div>

          <div class="relative mt-16 md:mt-24">
            <div
              id="process-line"
              class="absolute top-14 right-[12%] left-[12%] hidden h-px bg-[#E8C4B8] md:block"
              aria-hidden="true"
            ></div>

            <ol
              id="proceso-steps"
              class="grid grid-cols-1 gap-12 sm:grid-cols-2 md:grid-cols-4 md:gap-6"
            >
              {
                processSteps.map((step) => (
                  <li class="relative flex flex-col items-center text-center">
                    <div class="process-step-img">
                      <img src={step.image} alt="" width="80" height="80" loading="lazy" />
                      <span class="process-badge font-display flex items-center justify-center rounded-full">
                        {step.step}
                      </span>
                    </div>
                    <h3 class="font-display mt-4 text-xl font-medium">{step.title}</h3>
                    <p class="mt-2 max-w-[200px] text-sm font-light text-[#1A1A1A]/60">
                      {step.text}
                    </p>
                  </li>
                ))
              }
            </ol>
          </div>

          <div class="scroll-reveal mt-14 text-center">
            <a
              href={WA_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="section-whatsapp-cta"
            >
              Reservar por WhatsApp
            </a>
          </div>
        </div>
      </section>

      <!-- Ola: Proceso → Testimonios -->
      <div class="wave-divider" aria-hidden="true">
        <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
          <path
            fill="#FAF7F4"
            d="M0,40 C360,64 720,16 1080,48 1440,32 L1440,80 L0,80 Z"
          ></path>
        </svg>
      </div>

      <!-- 6. TESTIMONIOS (slider infinito CSS) -->
      <section
        id="testimonios"
        class="overflow-hidden bg-[#F5F0EB]/40 py-20 md:py-28"
        aria-label="Testimonios de clientas"
      >
        <div class="mx-auto max-w-6xl px-5 text-center md:px-8">
          <p class="section-label">Testimonios</p>
          <h2
            class="gsap-split-title font-display mt-2 text-3xl font-light text-[#1A1A1A] md:text-5xl"
          >
            Lo que dicen nuestras clientas
          </h2>
        </div>

        <div class="testimonial-slider-wrap mt-14">
          <div class="testimonial-slider-track" aria-hidden="true">
            {
              [...testimonials, ...testimonials].map((item) => (
                <blockquote class="testimonial-card-slide">
                  <p class="quote-text">"{item.text}"</p>
                  <p class="stars" aria-label="5 estrellas">⭐⭐⭐⭐⭐</p>
                  <div class="author-row">
                    {
                      item.image ? (
                        <img
                          src={item.image}
                          alt=""
                          width="56"
                          height="56"
                          class="testimonial-avatar"
                          loading="lazy"
                        />
                      ) : (
                        <span class="testimonial-avatar-initial" aria-hidden="true">
                          {item.initial}
                        </span>
                      )
                    }
                    <footer class="author">{item.name}</footer>
                  </div>
                </blockquote>
              ))
            }
          </div>
          <div class="sr-only">
            <ul>
              {testimonials.map((item) => (
                <li>
                  {item.name}: {item.text}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </section>

      <!-- Ola: Testimonios → CTA -->
      <div class="wave-divider" aria-hidden="true">
        <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
          <path
            fill="#E8C4B8"
            d="M0,48 C240,24 480,56 720,40 C960,24 1200,56 1440,40 L1440,80 L0,80 Z"
          ></path>
        </svg>
      </div>

      <!-- 7. CTA FINAL -->
      <section
        id="contacto"
        class="relative overflow-hidden px-5 py-20 md:px-8 md:py-28"
      >
        <img
          src="/imagenes/ambiente-spa.png"
          alt=""
          class="cta-visual-bg"
          loading="lazy"
          aria-hidden="true"
        />
        <div class="cta-visual-overlay" aria-hidden="true"></div>
        <div id="cta-content" class="relative z-10 mx-auto max-w-3xl text-center">
          <p class="section-label text-[#1A1A1A]/50">Tu momento</p>
          <h2
            class="font-display mt-4 text-3xl font-light text-[#1A1A1A] md:text-5xl"
          >
            ¿Lista para transformar tu piel?
          </h2>
          <p class="mt-4 text-base font-light text-[#1A1A1A]/75 md:text-lg">
            Agenda tu cita hoy y comienza tu transformación
          </p>
          <a
            id="cta-btn"
            href={WA_LINK}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-10 inline-flex items-center justify-center gap-3 rounded-full bg-[#1A1A1A] px-10 py-5 text-sm font-medium tracking-widest text-white uppercase transition-all hover:scale-[1.02] hover:bg-[#1A1A1A]/90 hover:shadow-xl"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="h-5 w-5"
              aria-hidden="true"
            >
              <path
